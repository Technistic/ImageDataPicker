               .background(.blue.opacity(0.6))","                    .cornerRadius(12)","                }","                .padding(12)","                ","                Spacer()","            }","            ","            Spacer()","        }","        .frame(width: 360)","        .onAppear {","            loadSelectedImage()","        }","    }","","    private func loadSelectedImage() {","        guard let selectedImageID = selectedImageID else { return }","        ","        myImage = modelContext.registeredModel(for: selectedImageID)","        ","        if let myImage = myImage {","            imageName = myImage.imageName","            imageData = myImage.imageData","        }","    }","","}","","#Preview {","    @Previewable @State var selectedImageID: MyImage.ID? = nil","    MyImageView(selectedImageID: $selectedImageID)","}"],"fileName":"MyImageView.swift","highlights":[{"line":9},{"line":10},{"line":14},{"line":15},{"line":16},{"line":17},{"line":18},{"line":19},{"line":20},{"line":21},{"line":23},{"line":24},{"line":25},{"line":26},{"line":27},{"line":28},{"line":29},{"line":30},{"line":31},{"line":32},{"line":33},{"line":34},{"line":35},{"line":36},{"line":37},{"line":38},{"line":39},{"line":40},{"line":41},{"line":42},{"line":43},{"line":44},{"line":45},{"line":46},{"line":47},{"line":48},{"line":49},{"line":50},{"line":51},{"line":52},{"line":53},{"line":54},{"line":55},{"line":56},{"line":57},{"line":58},{"line":59},{"line":60},{"line":61},{"line":63},{"line":67},{"line":68}],"fileType":"swift","identifier":"5-4-MyImageView.swift","type":"file","syntax":"swift"},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPicker/Customizing-Placeholders":{"identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPicker\/Customizing-Placeholders","type":"topic","abstract":[{"type":"text","text":"How to customize placeholder images in the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.technistic.ImageDataPicker\/documentation\/ImageDataPicker\/ImageDataPickerView"},{"type":"text","text":"."}],"url":"\/tutorials\/imagedatapicker\/customizing-placeholders","role":"project","estimatedTime":"10min","kind":"project","title":"Customizing Placeholder Images"},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPicker/Building":{"url":"\/tutorials\/imagedatapicker\/building","title":"Build a multiplatform App","role":"article","identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPicker\/Building","estimatedTime":"5min","type":"topic","kind":"article","abstract":[{"text":"Walk-through, step-by-step, how to create a SwiftUI multiplatform App that uses the ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"ImageDataPicker"}]},{"text":" framework.","type":"text"}]},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPicker/Building-ListView#Add-the-MyImageListView":{"title":"Add the MyImageListView","abstract":[{"text":"Create a ","type":"text"},{"code":"List","type":"codeVoice"},{"text":" view within a ","type":"text"},{"code":"NavigationSplitView","type":"codeVoice"},{"text":" to display the ","type":"text"},{"inlineContent":[{"type":"text","text":"List"}],"type":"strong"},{"text":" of Images and navigate to a ","type":"text"},{"inlineContent":[{"type":"text","text":"Detail"}],"type":"strong"},{"text":" view for each one .","type":"text"}],"role":"pseudoSymbol","identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPicker\/Building-ListView#Add-the-MyImageListView","kind":"section","type":"section","url":"\/tutorials\/imagedatapicker\/building-listview#Add-the-MyImageListView"},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPicker/Understanding-Overview":{"estimatedTime":"5min","type":"topic","url":"\/tutorials\/imagedatapicker\/understanding-overview","kind":"article","identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPicker\/Understanding-Overview","title":"Overview of the Framework","abstract":[{"text":"The ","type":"text"},{"inlineContent":[{"type":"text","text":"ImageDataPicker Framework"}],"type":"strong"},{"text":" provides a SwiftUI view that allows users to select photos from their photo library and bind the resulting ","type":"text"},{"code":"Data?","type":"codeVoice"},{"text":" to app state or a SwiftData model.","type":"text"}],"role":"article"},"5-MyImageView.png":{"type":"image","variants":[{"url":"\/images\/com.technistic.ImageDataPicker\/5-MyImageView@1x.png","traits":["1x","light"]},{"url":"\/images\/com.technistic.ImageDataPicker\/5-MyImageView@2x.png","traits":["2x","light"]}],"identifier":"5-MyImageView.png","alt":"List Background"},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPickerTOC":{"kind":"overview","type":"topic","abstract":[{"type":"text","text":"Learn how to install the framework, incorporate it in your app, and prepare a shipping build for release."}],"identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPickerTOC","title":"Using the ImageDataPicker Framework","url":"\/tutorials\/imagedatapickertoc","role":"overview"},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPicker/Releasing-Entitlements#Configure-Entitlements":{"type":"section","title":"Configure Entitlements","url":"\/tutorials\/imagedatapicker\/releasing-entitlements#Configure-Entitlements","kind":"section","identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPicker\/Releasing-Entitlements#Configure-Entitlements","role":"pseudoSymbol","abstract":[{"text":"Review the following runtime permissions before distributing an app that uses ImageDataPicker.","type":"text"}]},"5-7-MyImageListView.swift":{"syntax":"swift","highlights":[{"line":13},{"line":14},{"line":15},{"line":52},{"line":54},{"line":55},{"line":104},{"line":105},{"line":106},{"line":107},{"line":108},{"line":109},{"line":110},{"line":111},{"line":112},{"line":114},{"line":121}],"fileType":"swift","identifier":"5-7-MyImageListView.swift","fileName":"MyImageListView.swift","content":["\/\/","\/\/  MyImageListView.swift","\/\/  MyImageList","\/\/","\/\/  Copyright © 2025 Technistic Pty Ltd.","\/\/  Refer to LICENSE file for licensing terms.","\/\/","","import ImageDataPicker","import SwiftData","import SwiftUI","","let emptyPlaceholder = \"photo.fill\"","let failurePlaceholder = \"exclamationmark.triangle\"","","struct MyImageListView: View {","    @Environment(\\.dismiss) private var dismiss","    ","    @Environment(\\.modelContext) private var modelContext","    @Query private var myImages: [MyImage]","    ","    @State private var selectedImageID: MyImage.ID? = nil","    @State private var columnVisibility = NavigationSplitViewVisibility","        .doubleColumn","    ","    var body: some View {","        NavigationSplitView(columnVisibility: $columnVisibility) {","            List(selection: $selectedImageID) {","                ForEach(myImages) { myImage in","                    MyImageListRow(myImage: myImage)","                }","                .onDelete(perform: deleteMyImages)","            }","            .navigationTitle(\"My Images\")","            .environment(\\.defaultMinListRowHeight, 100)","#if os(macOS)","            .navigationSplitViewColumnWidth(min: 180, ideal: 200)","#endif","            .toolbar {","#if os(iOS)","                ToolbarItem(placement: .navigationBarTrailing) {","                    EditButton()","                }","#endif","                ToolbarItem {","                    Button(action: addImage) {","                        Label(\"Add Image\", systemImage: \"plus\")","                    }","                }","            }","        } detail: {","            if selectedImageID == nil {","                Text(\"Please select an image.\")","            } else {","                MyImageView(selectedImageID: $selectedImageID)","            }","        }","    }","    ","    \/\/\/ Add a new Image.","    \/\/\/ Initially imageData defaults to nil.","    private func addImage() {","        withAnimation {","            let newImage = MyImage(","                imageName: \"New Image\"","            )","            modelContext.insert(newImage)","            selectedImageID = newImage.persistentModelID","        }","    }","","    \/\/\/ Delete the selected Image.","    \/\/\/ - Parameter offsets: The index(es) of the rows to delete.","    private func deleteMyImages(offsets: IndexSet) {","        withAnimation {","            for index in offsets {","                let deletedImage = myImages[index]","                if deletedImage.persistentModelID == selectedImageID {","                    selectedImageID = nil","                }","                modelContext.delete(deletedImage)","                if modelContext.hasChanges {","                    do {","                        try modelContext.save()","                    }","                    catch {","                        print(\"Error: \\(error)\")","                    }","                }","            }","        }","    }","}","","\/\/ MyImageListRow","struct MyImageListRow: View {","    var myImage: MyImage?","","    var body: some View {","        @State var img: Data? = myImage?.imageData","        @State var state: ImageDataModel = ImageDataModel(imageData: img)","            ","        HStack {","            VStack {","                ImageStateView(","                    imageState: state.imageState, emptyPlaceholder: emptyPlaceholder","                )","                .foregroundColor(.white)","                .squareImageView(shape: Circle(), background: .green)","                .background(Color.blue)","            }","            .frame(width: 80, height: 80)","            Text(myImage!.imageName)","                .padding(4)","        }","    }","}","","#Preview {","    MyImageListView()","        .modelContainer(for: MyImage.self, inMemory: true)","}"],"type":"file"},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPicker/Starting-AddFramework#Add-with-Swift-Package-Manager":{"abstract":[{"type":"text","text":"How to add the ImageDataPicker framework to your project, either through Swift Package Manager or as a downloaded xcframework."}],"type":"section","kind":"section","title":"Add with Swift Package Manager","role":"pseudoSymbol","identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPicker\/Starting-AddFramework#Add-with-Swift-Package-Manager","url":"\/tutorials\/imagedatapicker\/starting-addframework#Add-with-Swift-Package-Manager"}}}