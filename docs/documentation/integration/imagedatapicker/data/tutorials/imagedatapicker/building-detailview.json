rview","type":"topic","kind":"article","abstract":[{"text":"The ","type":"text"},{"inlineContent":[{"text":"ImageDataPicker Framework","type":"text"}],"type":"strong"},{"text":" provides a SwiftUI view that allows users to select photos from their photo library and bind the resulting ","type":"text"},{"code":"Data?","type":"codeVoice"},{"text":" to app state or a SwiftData model.","type":"text"}],"identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPicker\/Understanding-Overview","role":"article","title":"Overview of the Framework"},"5-2-NewViewFile-MyImageView.png":{"alt":"Xcode Framework Embed","type":"image","identifier":"5-2-NewViewFile-MyImageView.png","variants":[{"url":"\/images\/com.technistic.ImageDataPicker\/5-2-NewViewFile-MyImageView.png","traits":["1x","light"]}]},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPicker/Starting-AddFramework#Add-the-XCFramework-to-your-Project":{"type":"section","kind":"section","title":"Add the XCFramework to your Project","identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPicker\/Starting-AddFramework#Add-the-XCFramework-to-your-Project","role":"pseudoSymbol","url":"\/tutorials\/imagedatapicker\/starting-addframework#Add-the-XCFramework-to-your-Project","abstract":[{"text":"How to add the ImageDataPicker framework to your project, either through Swift Package Manager or as a downloaded xcframework.","type":"text"}]},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPicker/Customizing-Placeholders":{"kind":"project","title":"Customizing Placeholder Images","type":"topic","abstract":[{"type":"text","text":"How to customize placeholder images in the "},{"identifier":"doc:\/\/com.technistic.ImageDataPicker\/documentation\/ImageDataPicker\/ImageDataPickerView","type":"reference","isActive":true},{"type":"text","text":"."}],"estimatedTime":"10min","identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPicker\/Customizing-Placeholders","url":"\/tutorials\/imagedatapicker\/customizing-placeholders","role":"project"},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPicker/Releasing-Signing#Verify-App-Signing":{"type":"section","title":"Verify App Signing","identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPicker\/Releasing-Signing#Verify-App-Signing","kind":"section","url":"\/tutorials\/imagedatapicker\/releasing-signing#Verify-App-Signing","role":"pseudoSymbol","abstract":[{"type":"text","text":"Review the following aspects of your app before distribution when using the xcframework form of ImageDataPicker."}]},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPicker/Starting-Extract#Extracting-the-Archive":{"type":"section","kind":"section","identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPicker\/Starting-Extract#Extracting-the-Archive","abstract":[{"text":"Expand the downloaded Framework Archive.","type":"text"}],"url":"\/tutorials\/imagedatapicker\/starting-extract#Extracting-the-Archive","role":"pseudoSymbol","title":"Extracting the Archive"},"Phone-Header-R.png":{"type":"image","identifier":"Phone-Header-R.png","alt":"Phone Background","variants":[{"traits":["1x","light"],"url":"\/images\/com.technistic.ImageDataPicker\/Phone-Header-R@1x.png"},{"traits":["2x","light"],"url":"\/images\/com.technistic.ImageDataPicker\/Phone-Header-R@2x.png"}]},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPickerTOC/Getting-Started":{"abstract":[],"kind":"article","url":"\/tutorials\/imagedatapickertoc\/getting-started","identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPickerTOC\/Getting-Started","type":"topic","title":"Getting Started","role":"article"},"5-7-MyImageListView.swift":{"fileType":"swift","fileName":"MyImageListView.swift","identifier":"5-7-MyImageListView.swift","content":["\/\/","\/\/  MyImageListView.swift","\/\/  MyImageList","\/\/","\/\/  Copyright © 2025 Technistic Pty Ltd.","\/\/  Refer to LICENSE file for licensing terms.","\/\/","","import ImageDataPicker","import SwiftData","import SwiftUI","","let emptyPlaceholder = \"photo.fill\"","let failurePlaceholder = \"exclamationmark.triangle\"","","struct MyImageListView: View {","    @Environment(\\.dismiss) private var dismiss","    ","    @Environment(\\.modelContext) private var modelContext","    @Query private var myImages: [MyImage]","    ","    @State private var selectedImageID: MyImage.ID? = nil","    @State private var columnVisibility = NavigationSplitViewVisibility","        .doubleColumn","    ","    var body: some View {","        NavigationSplitView(columnVisibility: $columnVisibility) {","            List(selection: $selectedImageID) {","                ForEach(myImages) { myImage in","                    MyImageListRow(myImage: myImage)","                }","                .onDelete(perform: deleteMyImages)","            }","            .navigationTitle(\"My Images\")","            .environment(\\.defaultMinListRowHeight, 100)","#if os(macOS)","            .navigationSplitViewColumnWidth(min: 180, ideal: 200)","#endif","            .toolbar {","#if os(iOS)","                ToolbarItem(placement: .navigationBarTrailing) {","                    EditButton()","                }","#endif","                ToolbarItem {","                    Button(action: addImage) {","                        Label(\"Add Image\", systemImage: \"plus\")","                    }","                }","            }","        } detail: {","            if selectedImageID == nil {","                Text(\"Please select an image.\")","            } else {","                MyImageView(selectedImageID: $selectedImageID)","            }","        }","    }","    ","    \/\/\/ Add a new Image.","    \/\/\/ Initially imageData defaults to nil.","    private func addImage() {","        withAnimation {","            let newImage = MyImage(","                imageName: \"New Image\"","            )","            modelContext.insert(newImage)","            selectedImageID = newImage.persistentModelID","        }","    }","","    \/\/\/ Delete the selected Image.","    \/\/\/ - Parameter offsets: The index(es) of the rows to delete.","    private func deleteMyImages(offsets: IndexSet) {","        withAnimation {","            for index in offsets {","                let deletedImage = myImages[index]","                if deletedImage.persistentModelID == selectedImageID {","                    selectedImageID = nil","                }","                modelContext.delete(deletedImage)","                if modelContext.hasChanges {","                    do {","                        try modelContext.save()","                    }","                    catch {","                        print(\"Error: \\(error)\")","                    }","                }","            }","        }","    }","}","","\/\/ MyImageListRow","struct MyImageListRow: View {","    var myImage: MyImage?","","    var body: some View {","        @State var img: Data? = myImage?.imageData","        @State var state: ImageDataModel = ImageDataModel(imageData: img)","            ","        HStack {","            VStack {","                ImageStateView(","                    imageState: state.imageState, emptyPlaceholder: emptyPlaceholder","                )","                .foregroundColor(.white)","                .squareImageView(shape: Circle(), background: .green)","                .background(Color.blue)","            }","            .frame(width: 80, height: 80)","            Text(myImage!.imageName)","                .padding(4)","        }","    }","}","","#Preview {","    MyImageListView()","        .modelContainer(for: MyImage.self, inMemory: true)","}"],"highlights":[{"line":13},{"line":14},{"line":15},{"line":52},{"line":54},{"line":55},{"line":104},{"line":105},{"line":106},{"line":107},{"line":108},{"line":109},{"line":110},{"line":111},{"line":112},{"line":114},{"line":121}],"type":"file","syntax":"swift"},"doc://c