xt","text":"Download the latest version of the "},{"type":"strong","inlineContent":[{"type":"text","text":"ImageDataPicker"}]},{"type":"text","text":" framework from the official repository."},{"type":"text","text":" "},{"type":"text","text":"Extract the archive and add the Framework to your Xcode project."}],"role":"pseudoSymbol","kind":"section","identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPicker\/Starting-Download#Download-the-Framework","url":"\/tutorials\/imagedatapicker\/starting-download#Download-the-Framework","type":"section"},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPicker/Releasing-Entitlements":{"title":"App Entitlements","identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPicker\/Releasing-Entitlements","role":"project","url":"\/tutorials\/imagedatapicker\/releasing-entitlements","type":"topic","kind":"project","abstract":[{"type":"text","text":"Review the following aspects of your app before submitting to the "},{"type":"strong","inlineContent":[{"type":"text","text":"AppStore"}]},{"type":"text","text":" when using the ImageDataPicker framework."}],"estimatedTime":"5min"},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPicker/Starting-Extract":{"type":"topic","identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPicker\/Starting-Extract","kind":"project","abstract":[{"type":"text","text":"Expand the downloaded Framework Archive."}],"title":"Extract the Archive","url":"\/tutorials\/imagedatapicker\/starting-extract","estimatedTime":"5min","role":"project"},"4-6-MyImageListView.swift":{"fileType":"swift","type":"file","highlights":[{"line":9},{"line":27},{"line":93},{"line":94},{"line":95},{"line":96},{"line":97},{"line":98},{"line":99},{"line":100},{"line":101},{"line":102},{"line":103},{"line":104},{"line":105},{"line":106},{"line":107},{"line":108},{"line":109}],"content":["\/\/","\/\/  MyImageListView.swift","\/\/  MyImageList","\/\/","\/\/  Copyright © 2025 Technistic Pty Ltd.","\/\/  Refer to LICENSE file for licensing terms.","\/\/","","import ImageDataPicker","import SwiftData","import SwiftUI","","struct MyImageListView: View {","    @Environment(\\.dismiss) private var dismiss","    ","    @Environment(\\.modelContext) private var modelContext","    @Query private var myImages: [MyImage]","    ","    @State private var selectedImageID: MyImage.ID? = nil","    @State private var columnVisibility = NavigationSplitViewVisibility","        .doubleColumn","    ","    var body: some View {","        NavigationSplitView(columnVisibility: $columnVisibility) {","            List(selection: $selectedImageID) {","                ForEach(myImages) { myImage in","                    MyImageListRow(myImage: myImage)","                }","                .onDelete(perform: deleteMyImages)","            }","            .navigationTitle(\"My Images\")","            .environment(\\.defaultMinListRowHeight, 100)","#if os(macOS)","            .navigationSplitViewColumnWidth(min: 180, ideal: 200)","#endif","            .toolbar {","#if os(iOS)","                ToolbarItem(placement: .navigationBarTrailing) {","                    EditButton()","                }","#endif","                ToolbarItem {","                    Button(action: addImage) {","                        Label(\"Add Image\", systemImage: \"plus\")","                    }","                }","            }","        } detail: {","            if let selectedImageID = selectedImageID {","                let myImage: MyImage? = modelContext.registeredModel(for: selectedImageID)","                myImage!.photo","            } else {","                Text(\"Please select an image.\")","            }","        }","    }","    ","    \/\/\/ Add a new Image.","    \/\/\/ Initially imageData defaults to nil.","    private func addImage() {","        withAnimation {","            let newImage = MyImage(","                imageName: \"New Image\"","            )","            modelContext.insert(newImage)","            selectedImageID = newImage.persistentModelID","        }","    }","","    \/\/\/ Delete the selected Image.","    \/\/\/ - Parameter offsets: The index(es) of the rows to delete.","    private func deleteMyImages(offsets: IndexSet) {","        withAnimation {","            for index in offsets {","                let deletedImage = myImages[index]","                if deletedImage.persistentModelID == selectedImageID {","                    selectedImageID = nil","                }","                modelContext.delete(deletedImage)","                if modelContext.hasChanges {","                    do {","                        try modelContext.save()","                    }","                    catch {","                        print(\"Error: \\(error)\")","                    }","                }","            }","        }","    }","}","","\/\/ MyImageListRow","struct MyImageListRow: View {","    var myImage: MyImage?","","    var body: some View {","        @State var img: Data? = myImage?.imageData","        @State var state: ImageDataModel = ImageDataModel(imageData: img)","            ","        HStack {","            ClippedImageStateView(imageState: state.imageState)","                .clippedImageShape(.round)","            Text(myImage!.imageName)","        }","        .padding(4)","    }","}","","#Preview {","    MyImageListView()","        .modelContainer(for: MyImage.self)","}"],"identifier":"4-6-MyImageListView.swift","syntax":"swift","fileName":"MyImageListView.swift"},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPicker/Starting-Extract#Extracting-the-Archive":{"abstract":[{"text":"Expand the downloaded Framework Archive.","type":"text"}],"identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPicker\/Starting-Extract#Extracting-the-Archive","role":"pseudoSymbol","kind":"section","url":"\/tutorials\/imagedatapicker\/starting-extract#Extracting-the-Archive","type":