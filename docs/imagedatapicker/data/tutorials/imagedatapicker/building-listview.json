erTOC","title":"Using the ImageDataPicker Framework","kind":"overview","url":"\/tutorials\/imagedatapickertoc","abstract":[{"text":"Learn how to install the framework, incorporate it in your app, and prepare a shipping build for release.","type":"text"}],"role":"overview"},"4-3-MyImageListViewSrc.png":{"identifier":"4-3-MyImageListViewSrc.png","variants":[{"url":"\/images\/com.technistic.ImageDataPicker\/4-3-MyImageListViewSrc.png","traits":["1x","light"]}],"type":"image","alt":"Xcode Framework Embed"},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPicker/Starting-Download#Download-the-Framework":{"url":"\/tutorials\/imagedatapicker\/starting-download#Download-the-Framework","abstract":[{"type":"text","text":"Download the latest version of the "},{"type":"strong","inlineContent":[{"text":"ImageDataPicker","type":"text"}]},{"type":"text","text":" framework from the official repository."},{"type":"text","text":" "},{"type":"text","text":"Extract the archive and add the Framework to your Xcode project."}],"type":"section","title":"Download the Framework","role":"pseudoSymbol","identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPicker\/Starting-Download#Download-the-Framework","kind":"section"},"4-6-MyImageListView.swift":{"content":["\/\/","\/\/  MyImageListView.swift","\/\/  MyImageList","\/\/","\/\/  Copyright © 2025 Technistic Pty Ltd.","\/\/  Refer to LICENSE file for licensing terms.","\/\/","","import ImageDataPicker","import SwiftData","import SwiftUI","","struct MyImageListView: View {","    @Environment(\\.dismiss) private var dismiss","    ","    @Environment(\\.modelContext) private var modelContext","    @Query private var myImages: [MyImage]","    ","    @State private var selectedImageID: MyImage.ID? = nil","    @State private var columnVisibility = NavigationSplitViewVisibility","        .doubleColumn","    ","    var body: some View {","        NavigationSplitView(columnVisibility: $columnVisibility) {","            List(selection: $selectedImageID) {","                ForEach(myImages) { myImage in","                    MyImageListRow(myImage: myImage)","                }","                .onDelete(perform: deleteMyImages)","            }","            .navigationTitle(\"My Images\")","            .environment(\\.defaultMinListRowHeight, 100)","#if os(macOS)","            .navigationSplitViewColumnWidth(min: 180, ideal: 200)","#endif","            .toolbar {","#if os(iOS)","                ToolbarItem(placement: .navigationBarTrailing) {","                    EditButton()","                }","#endif","                ToolbarItem {","                    Button(action: addImage) {","                        Label(\"Add Image\", systemImage: \"plus\")","                    }","                }","            }","        } detail: {","            if let selectedImageID = selectedImageID {","                let myImage: MyImage? = modelContext.registeredModel(for: selectedImageID)","                myImage!.photo","            } else {","                Text(\"Please select an image.\")","            }","        }","    }","    ","    \/\/\/ Add a new Image.","    \/\/\/ Initially imageData defaults to nil.","    private func addImage() {","        withAnimation {","            let newImage = MyImage(","                imageName: \"New Image\"","            )","            modelContext.insert(newImage)","            selectedImageID = newImage.persistentModelID","        }","    }","","    \/\/\/ Delete the selected Image.","    \/\/\/ - Parameter offsets: The index(es) of the rows to delete.","    private func deleteMyImages(offsets: IndexSet) {","        withAnimation {","            for index in offsets {","                let deletedImage = myImages[index]","                if deletedImage.persistentModelID == selectedImageID {","                    selectedImageID = nil","                }","                modelContext.delete(deletedImage)","                if modelContext.hasChanges {","                    do {","                        try modelContext.save()","                    }","                    catch {","                        print(\"Error: \\(error)\")","                    }","                }","            }","        }","    }","}","","\/\/ MyImageListRow","struct MyImageListRow: View {","    var myImage: MyImage?","","    var body: some View {","        @State var img: Data? = myImage?.imageData","        @State var state: ImageDataModel = ImageDataModel(imageData: img)","            ","        HStack {","            ClippedImageStateView(imageState: state.imageState)","                .clippedImageShape(.round)","            Text(myImage!.imageName)","        }","        .padding(4)","    }","}","","#Preview {","    MyImageListView()","        .modelContainer(for: MyImage.self)","}"],"highlights":[{"line":9},{"line":27},{"line":89},{"line":90},{"line":91},{"line":92},{"line":93},{"line":94},{"line":95},{"line":96},{"line":97},{"line":98},{"line":99},{"line":100},{"line":101},{"line":102},{"line":103},{"line":104},{"line":106}],"fileType":"swift","syntax":"swift","type":"file","identifier":"4-6-MyImageListView.swift","fileName":"MyImageListView.swift"},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPicker/Releasing-Signing":{"identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPicker\/Releasing-Signing","type":"topic","title":"App Signing","kind":"project","abstract":[{"text":"Review the following aspects of your app before distribution when using the xcframework form of ImageDataPicker.","type":"text"}],"url":"\/tutorials\/imagedatapicker\/releasing-signing","role":"project","estimatedTime":"5min"},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPicker/Customizing-Placeholders#Customizing-Placeholder-Images":{"url":"\/tutorials\/imagedatapicker\/customizing-placeholders#Customizing-Placeholder-Images","role":"pseudoSymbol","type":"section","identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPicker\/Customizing-Placeholders#Customizing-Placeholder-Images","title":"Customizing Placeholder Images","abstract":[{"text":"How to customize placeholder images in the ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.technistic.ImageDataPicker\/documentation\/ImageDataPicker\/ImageDataPickerView","type":"reference"},{"text":".","type":"text"}],"kind":"section"},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPicker/Building-DataModel#Create-the-Data-Model":{"role":"pseudoSymbol","title":"Create the Data Model","identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPicker\/Building-DataModel#Create-the-Data-Model","kind":"section","type":"section","url":"\/tutorials\/imagedatapicker\/building-datamodel#Create-the-Data-Model","abstract":[{"type":"text","text":"Add a SwiftData Model to your project to store a list of images."}]},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPicker/Building":{"type":"topic","role":"article","title":"Build a multiplatform App","abstract":[{"type":"text","text":"Walk-through, step-by-step, how to create a SwiftUI multiplatform App that uses the "},{"type":"strong","inlineContent":[{"type":"text","text":"ImageDataPicker"}]},{"type":"text","text":" framework."}],"estimatedTime":"5min","url":"\/tutorials\/imagedatapicker\/building","identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPicker\/Building","kind":"article"},"doc://com.technistic.ImageDataPicker/documentation/ImageDataPicker/ImageDataPickerView":{"abstract":[{"type":"text","text":"A SwiftUI view that lets the user select, preview, replace, and remove a photo."}],"title":"ImageDataPickerView","identifier":"doc:\/\/com.technistic.ImageDataPicker\/documentation\/ImageDataPicker\/ImageDataPickerView","type":"topic","url":"\/documentation\/imagedatapicker\/imagedatapickerview","role":"symbol","kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},