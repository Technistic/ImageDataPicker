 var body: some View {","        NavigationSplitView(columnVisibility: $columnVisibility) {","            List(selection: $selectedImageID) {","                ForEach(myImages) { myImage in","                    MyImageListRow(myImage: myImage)","                }","                .onDelete(perform: deleteMyImages)","            }","            .navigationTitle(\"My Images\")","            .environment(\\.defaultMinListRowHeight, 100)","#if os(macOS)","            .navigationSplitViewColumnWidth(min: 180, ideal: 200)","#endif","            .toolbar {","#if os(iOS)","                ToolbarItem(placement: .navigationBarTrailing) {","                    EditButton()","                }","#endif","                ToolbarItem {","                    Button(action: addImage) {","                        Label(\"Add Image\", systemImage: \"plus\")","                    }","                }","            }","        } detail: {","            if selectedImageID == nil {","                Text(\"Please select an image.\")","            } else {","                MyImageView(selectedImageID: $selectedImageID)","            }","        }","    }","    ","    \/\/\/ Add a new Image.","    \/\/\/ Initially imageData defaults to nil.","    private func addImage() {","        withAnimation {","            let newImage = MyImage(","                imageName: \"New Image\"","            )","            modelContext.insert(newImage)","            selectedImageID = newImage.persistentModelID","        }","    }","","    \/\/\/ Delete the selected Image.","    \/\/\/ - Parameter offsets: The index(es) of the rows to delete.","    private func deleteMyImages(offsets: IndexSet) {","        withAnimation {","            for index in offsets {","                let deletedImage = myImages[index]","                if deletedImage.persistentModelID == selectedImageID {","                    selectedImageID = nil","                }","                modelContext.delete(deletedImage)","                if modelContext.hasChanges {","                    do {","                        try modelContext.save()","                    }","                    catch {","                        print(\"Error: \\(error)\")","                    }","                }","            }","        }","    }","}","","\/\/ MyImageListRow","struct MyImageListRow: View {","    var myImage: MyImage?","","    var body: some View {","        @State var img: Data? = myImage?.imageData","        @State var state: ImageDataModel = ImageDataModel(imageData: img)","            ","        HStack {","            ClippedImageStateView(imageState: state.imageState)","                .clippedImageShape(.round)","            Text(myImage!.imageName)","        }","        .padding(4)","    }","}","","#Preview {","    MyImageListView()","        .modelContainer(for: MyImage.self, inMemory: true)","}"],"fileType":"swift"},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPicker/Building-DataModel#Create-the-Data-Model":{"identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPicker\/Building-DataModel#Create-the-Data-Model","type":"section","role":"pseudoSymbol","url":"\/tutorials\/imagedatapicker\/building-datamodel#Create-the-Data-Model","abstract":[{"text":"Add a SwiftData Model to your project to store a list of images.","type":"text"}],"kind":"section","title":"Create the Data Model"},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPicker/Understanding-Usage":{"type":"topic","title":"Using the Framework","identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPicker\/Understanding-Usage","role":"article","kind":"article","estimatedTime":"5min","url":"\/tutorials\/imagedatapicker\/understanding-usage","abstract":[{"type":"text","text":"It is simple to incorporate the "},{"type":"strong","inlineContent":[{"text":"ImageDataPicker Framework","type":"text"}]},{"type":"text","text":" in your application. Download the Framework, add it to your Project, create a "},{"type":"strong","inlineContent":[{"type":"text","text":"SwiftData Model"}]},{"type":"text","text":" and "},{"type":"codeVoice","code":"@Bind"},{"type":"text","text":" the "},{"identifier":"doc:\/\/com.technistic.ImageDataPicker\/documentation\/ImageDataPicker\/ImageDataPickerView","type":"reference","isActive":true},{"type":"text","text":" to a property in your Model."}]},"doc://com.technistic.ImageDataPicker/documentation/ImageDataPicker/ImageDataPickerView":{"identifier":"doc:\/\/com.technistic.ImageDataPicker\/documentation\/ImageDataPicker\/ImageDataPickerView","type":"topic","abstract":[{"type":"text","text":"The ImageDataPickerView is a SwiftUI view that allows users to select and display an image from their photo library. It represents a thumbnail image that can be changed or removed. If no image is selected, a placeholder image is displayed. The placeholder image can be changed to any SF system image. The image will also change to a Progress view while an image is loading or a Failure image if the transfer is unsuccessful. The Failure image can also be customised to any SF system image."}],"url":"\/documentation\/imagedatapicker\/imagedatapickerview","kind":"symbol","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ImageDataPickerView","kind":"identifier"}],"navigatorTitle":[{"text":"ImageDataPickerView","kind":"identifier"}],"title":"ImageDataPickerView"},"5-6-MyImageView.swift":{"fileName":"MyImageView.swift","content":["\/\/","\/\/  MyImageView.swift","\/\/  MyImageList","\/\/","\/\/  Copyright © 2025 Technistic Pty Ltd.","\/\/  Refer to LICENSE file for licensing terms.","\/\/","","import ImageDataPicker","import SwiftData","import SwiftUI","","struct MyImageView: View {","    @Environment(\\.modelContext) private var modelContext","","    @Binding public var selectedImageID: MyImage.ID?","    @State private var myImage: MyImage?","","    @State private var imageName: String = \"\"","    @State private var imageData: Data? = nil","","    var body: some View {","        HStack {","            Spacer()","            ","            VStack {","                Section(header: Text(\"Selected Image\")) {","                    VStack {","                        ImageDataPickerView(imageData: $imageData)","                            .frame(width: 120, height: 120)","                        ","                        TextField(\"Enter Image Name\", text: $imageName)","                            .textFieldStyle(.roundedBorder)","                            .multilineTextAlignment(.center)","                    }","                    .padding(20)","                    .background(.blue.opacity(0.6))","                    .cornerRadius(12)","                    ","                    HStack {","                        Button(role: .cancel) {","                            cancelChanges()","                        } label: {","                            Text(\"Cancel\")","                                .frame(maxWidth: .infinity)","                        }","                        .buttonStyle(.bordered)","","                        Button {","                            saveImage()","                        } label: {","                            Text(\"Save\")","                                .frame(maxWidth: .infinity)","                        }","                        .disabled(!hasChanges)","                        .buttonStyle(.bordered)","                    }","                }","                .padding(12)","                ","                Spacer()","            }","            ","            Spacer()","        }","        .frame(width: 360)","        .onAppear {","            loadSelectedImage()","        }","    }","","    private var hasChanges: Bool {","        guard let myImage = myImage else { return false }","        return imageName != myImage.imageName || imageData != myImage.imageData","    }","","    private func loadSelectedImage() {","        guard let selectedImageID = selectedImageID else { return }","        ","        myImage = modelContext.registeredModel(for: selectedImageID)","        ","        if let myImage = myImage {","            imageName = myImage.imageName","            imageData = myImage.imageData","        }","    }","","    private func cancelChanges() {","        guard let myImage = myImage else { return }","        ","        imageName = myImage.imageName","        imageData = myImage.imageData","        modelContext.rollback()","        selectedImageID = nil","    }","","    private func saveImage() {","        guard let myImage = myImage else { return }","        ","        myImage.imageName = imageName","        myImage.imageData = imageData","        ","        do {","            try modelContext.save()","        } catch {","            print(\"Error: \\(error.localizedDescription)\")","        }","        ","        selectedImageID = nil","    }","}","","#Preview {","    @Previewable @State var selectedImageID: MyImage.ID? = nil","    MyImageView(selectedImageID: $selectedImageID)","}"],"fileType":"swift","highlights":[{"line":39},{"line":40},{"line":41},{"line":42},{"line":43},{"line":44},{"line":45},{"line":46},{"line":47},{"line":48},{"line":49},{"line":50},{"line":51},{"line":52},{"line":53},{"line":54},{"line":55},{"line":56},{"line":57},{"line":87},{"line":88},{"line":89},{"line":90},{"line":91},{"line":92},{"line":93},{"line":94},{"line":95},{"line":96},{"line":97},{"line":98},{"line":99},{"line":100},{"line":101},{"line":102},{"line":103},{"line":104},{"line":105},{"line":106},{"line":107},{"line":108},{"line":109},{"line":110}],"syntax":"swift","type":"file","identifier":"5-6-MyImageView.swift"},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPicker/Releasing-Entitlements":{"title":"App Entitlements","identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPicker\/Releasing-Entitlements","role":"project","url":"\/tu