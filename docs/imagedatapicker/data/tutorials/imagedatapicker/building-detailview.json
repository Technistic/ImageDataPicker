,"content":[{"inlineContent":[{"type":"text","text":"Use the MyImageView to display the selected image and its details. Present the image in an "},{"code":"ImageDataPickerView","type":"codeVoice"},{"type":"text","text":" that allows the user to select a new image or remove the current image."}],"type":"paragraph"}],"kind":"contentAndMedia"}]}]},{"title":"Customizing Placeholder Images","abstract":[{"type":"text","text":"How to customize placeholder images in the "},{"identifier":"doc:\/\/com.technistic.ImageDataPicker\/documentation\/ImageDataPicker\/ImageDataPickerView","isActive":true,"type":"reference"},{"type":"text","text":"."}],"kind":"callToAction","featuredEyebrow":"Tutorial","action":{"overridingTitleInlineContent":[{"text":"Get started","type":"text"}],"identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPicker\/Customizing-Placeholders","isActive":true,"type":"reference","overridingTitle":"Get started"}}],"schemaVersion":{"patch":0,"major":0,"minor":3},"references":{"5-3-MyImageView.swift":{"fileType":"swift","type":"file","highlights":[],"syntax":"swift","identifier":"5-3-MyImageView.swift","fileName":"MyImageView.swift","content":["\/\/","\/\/  MyImageView.swift","\/\/  MyImageList","\/\/","\/\/  Copyright © 2025 Technistic Pty Ltd.","\/\/  Refer to LICENSE file for licensing terms.","\/\/","","import SwiftUI","","struct MyImageView: View {","    var body: some View {","        Text(\"Hello, World!\")","    }","}","","#Preview {","    MyImageView()","}"]},"doc://com.technistic.ImageDataPicker/documentation/ImageDataPicker/ImageDataPickerView":{"url":"\/documentation\/imagedatapicker\/imagedatapickerview","role":"symbol","title":"ImageDataPickerView","type":"topic","abstract":[{"text":"The ImageDataPickerView is a SwiftUI view that allows users to select and display an image from their photo library. The data associated with the selected photo is bound to an ","type":"text"},{"code":"imageData","type":"codeVoice"},{"text":" property of type ","type":"text"},{"code":"Data?","type":"codeVoice"},{"text":",  to simplify integration with ","type":"text"},{"code":"SwiftData","type":"codeVoice"},{"text":". The View presents a thumbnail of the Image that can be changed or removed. If no Image is selected, a placeholder image is displayed. The placeholder image can be changed to any SF system image. The Image will also change to a Progress view while an image is loading or a Failure image if the transfer is unsuccessful. The Failure image can also be customised to any SF system image.","type":"text"}],"identifier":"doc:\/\/com.technistic.ImageDataPicker\/documentation\/ImageDataPicker\/ImageDataPickerView","navigatorTitle":[{"text":"ImageDataPickerView","kind":"identifier"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ImageDataPickerView","kind":"identifier"}],"kind":"symbol"},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPicker/Building-DetailView":{"title":"Create a Detail view","url":"\/tutorials\/imagedatapicker\/building-detailview","identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPicker\/Building-DetailView","type":"topic","abstract":[{"type":"text","text":"Add a Detail view to your SwiftUI project that allows users to view and select images."}],"role":"project","estimatedTime":"10min","kind":"project"},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPicker/Building-ListView":{"url":"\/tutorials\/imagedatapicker\/building-listview","title":"Create a List view","estimatedTime":"10min","type":"topic","identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPicker\/Building-ListView","role":"project","abstract":[{"text":"Create a ","type":"text"},{"code":"List","type":"codeVoice"},{"text":" view within a ","type":"text"},{"code":"NavigationSplitView","type":"codeVoice"},{"text":" to display the ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"List"}]},{"text":" of Images and navigate to a ","type":"text"},{"type":"strong","inlineContent":[{"text":"Detail","type":"text"}]},{"text":" view for each one .","type":"text"}],"kind":"project"},"5-7-MyImageListView.swift":{"type":"file","fileName":"MyImageListView.swift","content":["\/\/","\/\/  MyImageListView.swift","\/\/  MyImageList","\/\/","\/\/  Copyright © 2025 Technistic Pty Ltd.","\/\/  Refer to LICENSE file for licensing terms.","\/\/","","import ImageDataPicker","import SwiftData","import SwiftUI","","struct MyImageListView: View {","    @Environment(\\.dismiss) private var dismiss","    ","    @Environment(\\.modelContext) private var modelContext","    @Query private var myImages: [MyImage]","    ","    @State private var selectedImageID: MyImage.ID? = nil","    @State private var columnVisibility = NavigationSplitViewVisibility","        .doubleColumn","    ","    var body: some View {","        NavigationSplitView(columnVisibility: $columnVisibility) {","            List(selection: $selectedImageID) {","                ForEach(myImages) { myImage in","                    MyImageListRow(myImage: myImage)","                }","                .onDelete(perform: deleteMyImages)","            }","            .navigationTitle(\"My Images\")","            .environment(\\.defaultMinListRowHeight, 100)","#if os(macOS)","            .navigationSplitViewColumnWidth(min: 180, ideal: 200)","#endif","            .toolbar {","#if os(iOS)","                ToolbarItem(placement: .navigationBarTrailing) {","                    EditButton()","                }","#endif","                ToolbarItem {","                    Button(action: addImage) {","                        Label(\"Add Image\", systemImage: \"plus\")","                    }","                }","            }","        } detail: {","            if selectedImageID == nil {","                Text(\"Please select an image.\")","            } else {","                MyImageView(selectedImageID: $selectedImageID)","            }","        }","    }","    ","    \/\/\/ Add a new Image.","    \/\/\/ Initially imageData defaults to nil.","    private func addImage() {","        withAnimation {","            let newImage = MyImage(","                imageName: \"New Image\"","            )","            modelContext.insert(newImage)","            selectedImageID = newImage.persistentModelID","        }","    }","","    \/\/\/ Delete the selected Image.","    \/\/\/ - Parameter offsets: The index(es) of the rows to delete.","    private func deleteMyImages(offsets: IndexSet) {","        withAnimation {","            for index in offsets {","                let deletedImage = myImages[index]","                if deletedImage.persistentModelID == selectedImageID {","                    selectedImageID = nil","                }","                modelContext.delete(deletedImage)","                if modelContext.hasChanges {","                    do {","                        try modelContext.save()","                    }","                    catch {","                        print(\"Error: \\(error)\")","                    }","                }","            }","        }","    }","}","","\/\/ MyImageListRow","struct MyImageListRow: View {","    var myImage: MyImage?","","    var body: some View {","        @State var img: Data? = myImage?.imageData","        @State var state: ImageDataModel = ImageDataModel(imageData: img)","            ","        HStack {","            ClippedImageStateView(imageState: state.imageState)","                .clippedImageShape(.round)","            Text(myImage!.imageName)","        }","        .padding(4)","    }","}","","#Preview {","    MyImageListView()","        .modelContainer(for: MyImage.self, inMemory: true)","}"],"syntax":"swift","identifier":"5-7-MyImageListView.swift","fileType":"swift","highlights":[{"line":49},{"line":51},{"line":52},{"line":111}]},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPicker/Building-ListView#Add-a-NavigationSplitVie