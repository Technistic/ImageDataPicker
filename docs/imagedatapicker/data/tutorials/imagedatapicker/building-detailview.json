round(.blue.opacity(0.6))","                    .cornerRadius(12)","                    ","                    HStack {","                        Button(role: .cancel) {","                            cancelChanges()","                        } label: {","                            Text(\"Cancel\")","                                .frame(maxWidth: .infinity)","                        }","                        .buttonStyle(.bordered)","","                        Button {","                            saveImage()","                        } label: {","                            Text(\"Save\")","                                .frame(maxWidth: .infinity)","                        }","                        .disabled(!hasChanges)","                        .buttonStyle(.bordered)","                    }","                }","                .padding(12)","                ","                Spacer()","            }","            ","            Spacer()","        }","        .frame(width: 360)","        .onAppear {","            loadSelectedImage()","        }","    }","","    private var hasChanges: Bool {","        guard let myImage = myImage else { return false }","        return imageName != myImage.imageName || imageData != myImage.imageData","    }","","    private func loadSelectedImage() {","        guard let selectedImageID = selectedImageID else { return }","        ","        myImage = modelContext.registeredModel(for: selectedImageID)","        ","        if let myImage = myImage {","            imageName = myImage.imageName","            imageData = myImage.imageData","        }","    }","","    private func cancelChanges() {","        guard let myImage = myImage else { return }","        ","        imageName = myImage.imageName","        imageData = myImage.imageData","        modelContext.rollback()","        selectedImageID = nil","    }","","    private func saveImage() {","        guard let myImage = myImage else { return }","        ","        myIma