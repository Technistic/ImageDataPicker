icker\/tutorials\/ImageDataPicker\/Building-ListView#Add-the-MyImageListView","type":"section","url":"\/tutorials\/imagedatapicker\/building-listview#Add-the-MyImageListView","kind":"section"},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPickerTOC/Getting-Started":{"title":"Getting Started","kind":"article","identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPickerTOC\/Getting-Started","abstract":[],"role":"article","type":"topic","url":"\/tutorials\/imagedatapickertoc\/getting-started"},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPicker/Building-DataModel#Create-the-Data-Model":{"role":"pseudoSymbol","title":"Create the Data Model","identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPicker\/Building-DataModel#Create-the-Data-Model","kind":"section","type":"section","url":"\/tutorials\/imagedatapicker\/building-datamodel#Create-the-Data-Model","abstract":[{"type":"text","text":"Add a SwiftData Model to your project to store a list of images."}]},"5-6-MyImageView.swift":{"fileName":"MyImageView.swift","highlights":[{"line":39},{"line":40},{"line":41},{"line":42},{"line":43},{"line":44},{"line":45},{"line":46},{"line":47},{"line":48},{"line":49},{"line":50},{"line":51},{"line":52},{"line":53},{"line":54},{"line":55},{"line":56},{"line":57},{"line":85},{"line":86},{"line":87},{"line":88},{"line":89},{"line":90},{"line":91},{"line":92},{"line":93},{"line":94},{"line":95},{"line":96},{"line":97},{"line":98},{"line":99},{"line":100},{"line":101},{"line":102},{"line":103},{"line":104},{"line":105},{"line":106},{"line":108},{"line":109}],"content":["\/\/","\/\/  MyImageView.swift","\/\/  MyImageList","\/\/","\/\/  Copyright © 2025 Technistic Pty Ltd.","\/\/  Refer to LICENSE file for licensing terms.","\/\/","","import ImageDataPicker","import SwiftData","import SwiftUI","","struct MyImageView: View {","    @Environment(\\.modelContext) private var modelContext","","    @Binding public var selectedImageID: MyImage.ID?","    @State private var myImage: MyImage?","","    @State private var imageName: String = \"\"","    @State private var imageData: Data? = nil","","    var body: some View {","        HStack {","            Spacer()","            ","            VStack {","                Section(header: Text(\"Selected Image\")) {","                    VStack {","                        ImageDataPickerView(imageData: $imageData)","                            .frame(width: 120, height: 120)","                        ","                        TextField(\"Enter Image Name\", text: $imageName)","                            .textFieldStyle(.roundedBorder)","                            .multilineTextAlignment(.center)","                    }","                    .padding(20)","                    .background(.blue.opacity(0.6))","                    .cornerRadius(12)","                    ","                    HStack {","                        Button(role: .cancel) {","                            cancelChanges()","                        } label: {","                            Text(\"Cancel\")","                                .frame(maxWidth: .infinity)","                        }","                        .buttonStyle(.bordered)","","                        Button {","                            saveImage()","                        } label: {","                            Text(\"Save\")","                                .frame(maxWidth: .infinity)","                        }","                        .disabled(!hasChanges)","                        .buttonStyle(.bordered)","                    }","                }","                .padding(12)","                ","                Spacer()","            }","            ","            Spacer()","        }","        .frame(width: 360)","        .onAppear {","            loadSelectedImage()","        }","    }","","    private var hasChanges: Bool {","        guard let myImage = myImage else { return false }","        return imageName != myImage.imageName || imageData != myImage.imageData","    }","","    private func loadSelectedImage() {","        guard let selectedImageID = selectedImageID else { return }","        ","        myImage = modelContext.registeredModel(for: selectedImageID)","        ","        if let myImage = myImage {","            imageName = myImage.imageName","            imageData = myImage.imageData","        }","    }","","    private func cancelChanges() {","        guard let myImage = myImage else { return }","        ","        imageName = myImage.imageName","        imageData = myImage.imageData","        modelContext.rollback()","        selectedImageID = nil","    }","","    private func saveImage() {","        guard let myImage = myImage else { return }","        ","        myImage.imageName = imageName","        myImage.imageData = imageData","        ","        do {","            try modelContext.save()","        } catch {","            print(\"Error: \\(error.localizedDescription)\")","        }","        ","        selectedImageID = nil","    }","}","","#Preview {","    @Previewable @State var selectedImageID: MyImage.ID? = nil","    MyImageView(selectedImageID: $selectedImageID)","}"],"syntax":"swift","identifier":"5-6-MyImageView.swift","type":"file","fileType":"swift"},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPicker/Building":{"type":"topic","role":"article","title":"Build a multiplatform App","abstract":[{"type":"text","text":"Walk-through, step-by-step, how to create a SwiftUI multiplatform App that uses the "},{"type":"strong","inlineContent":[{"type":"text","text":"ImageDataPicker"}]},{"type":"text","text":" framework."}],"estimatedTime":"5min","url":"\/tutorials\/imagedatapicker\/building","identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPicker\/Building","kind":"article"},"Phone-Header-R.png":{"identifier":"Phone-Header-R.png","alt":"Phone Background","type":"image","variants":[{"url":"\/images\/com.technistic.ImageDataPicker\/Phone-Header-R@1x.png","traits":["1x","light"]},{"url":"\/images\/com.technistic.ImageDataPicker\/Phone-Header-R@2x.png","traits":["2x","light"]}]},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPicker/Building-CreateProject#Create-the-Project":{"url":"\/tutorials\/imagedatapicker\/building-createproject#Create-the-Project","abstract":[{"text":"Start by creating a new SwiftUI multiplatform project for the App.","type":"text"}],"type":"section","title":"Create the Project","identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPicker\/Building-CreateProject#Create-the-Project","role":"pseudoSymbol","kind":"section"},"5-7-MyImageListView.swift":{"identifier":"5-7-MyImageListView.swift","fileName":"MyImageListView.swift","fileType":"swift","type":"file","syntax":"swift","content":["\/\/","\/\/  MyImageListView.swift","\/\/  MyImageList","\/\/","\/\/  Copyright © 2025 Technistic Pty Ltd.","\/\/  Refer to LICENSE file for licensing terms.","\/\/","","import ImageDataPicker","import SwiftData","import SwiftUI","","let emptyPlaceholder = \"photo.fill\"","let failurePlaceholder = \"exclamationmark.triangle\"","","struct MyImageListView: View {","    @Environment(\\.dismiss) private var dismiss","    ","    @Environment(\\.modelContext) private var modelContext","    @Query private var myImages: [MyImage]","    ","    @State private var selectedImageID: MyImage.ID? = nil","    @State private var columnVisibility = NavigationSplitViewVisibility","        .doubleColumn","    ","    var body: some View {","        NavigationSplitView(columnVisibility: $columnVisibility) {","            List(selection: $selectedImageID) {","                ForEach(myImages) { myImage in","                    MyImageListRow(myImage: myImage)","                }","                .onDelete(perform: deleteMyImages)","            }","            .navigationTitle(\"My Images\")","            .environment(\\.defaultMinListRowHeight, 100)","#if os(macOS)","            .navigationSplitViewColumnWidth(min: 180, ideal: 200)","#endif","            .toolbar {","#if os(iOS)","                ToolbarItem(placement: .navigationBarTrailing) {","                    EditButton()","                }","#endif","                ToolbarItem {","                    Button(action: addImage) {","                        Label(\"Add Image\", systemImage: \"plus\")","                    }","                }","            }","        } detail: {","            if selectedImageID == nil {","                Text(\"Please select an image.\")","            } else {","                MyImageView(selectedImageID: $selectedImageID)","            }","        }","    }","    ","    \/\/\/ Add a new Image.","    \/\/\/ Initially imageData defaults to nil.","    private func addImage() {","        withAnimation {","            let newImage = MyImage(","                imageName: \"New Image\"","            )","            modelContext.insert(newImage)","            selectedImageID = newImage.persistentModelID","        }","    }","","    \/\/\/ Delete the selected Image.","    \/\/\/ - Parameter offsets: The index(es) of the rows to delete.","    private func deleteMyImages(offsets: IndexSet) {","        withAnimation {","            for index in offsets {","                let deletedImage = myImages[index]","                if deletedImage.persistentModelID == selectedImageID {","                    selectedImageID = nil","                }","                modelContext.delete(deletedImage)","                if modelContext.hasChanges {","                    do {","                        try modelContext.save()","                    }","                    catch {","                        print(\"Error: \\(error)\")","                    }","                }","            }","        }","    }","}","","\/\/ MyImageListRow","struct MyImageListRow: View {","    var myImage: MyImage?","","    var body: some View {","        @State var img: Data? = myImage?.imageData","        @State var state: ImageDataModel = ImageDataModel(imageData: img)","            ","        HStack {","            VStack {","                ImageStateView(","                    imageState: state.imageState, emptyPlaceholder: emptyPlaceholder","                )","                .foregroundColor(.white)","                .squareImageView(shape: Circle(), background: .green)","                .background(Color.blue)","            }","            .frame(width: 80, height: 80)","            Text(myImage!.imageName)","                .padding(4)","        }","    }","}","","#Preview {","    MyImageListView()","        .modelContainer(for: MyImage.self, inMemory: true)","}"],"highlights":[{"line":13},{"line":14},{"line":15},{"line":52},{"line":54},{"line":55},{"line":104},{"line":105},{"line":106},{"line":107},{"line":108},{"line":109},{"line":110},{"line":111},{"line":112},{"line":114},{"line":121}]},"doc://com.technistic.ImageDataPicker/documentation/ImageDataPicker/ImageDataPickerView":{"abstract":[{"type":"text","text":"A SwiftUI view that lets the user select, preview, replace, and remove a photo."}],"title":"ImageDataPickerView","identifier":"doc:\/\/com.technistic.ImageDataPicker\/documentation\/ImageDataPicker\/ImageDataPickerView","type":"topic","url":"\/documentation\/imagedatapicker\/imagedatapickerview","role":"symbol","kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"ImageDataPickerView"}],"navigatorTitle":[{"kind":"identifier","text":"ImageDataPickerView"}]},"5-3-MyImageView.swift":{"type":"file","fileType":"swift","highlights":[],"syntax":"swift","identifier":"5-3-MyImageView.swift","content":["\/\/","\/\/  MyImageView.swift","\/\/  MyImageList","\/\/","\/\/  Copyright © 2025 Technistic Pty Ltd.","\/\/  Refer to LICENSE file for licensing terms.","\/\/","","import SwiftUI","","struct MyImageView: View {","    var body: some View {","        