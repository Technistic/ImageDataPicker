 images, clipping shapes, and more to suit your application’s requirements."}],"title":"Customization Options","kind":"article","identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPicker\/Understanding-Customization","type":"topic","estimatedTime":"5min","url":"\/tutorials\/imagedatapicker\/understanding-customization"},"5-MyImageView.png":{"type":"image","variants":[{"url":"\/images\/com.technistic.ImageDataPicker\/5-MyImageView@1x.png","traits":["1x","light"]},{"url":"\/images\/com.technistic.ImageDataPicker\/5-MyImageView@2x.png","traits":["2x","light"]}],"alt":"List Background","identifier":"5-MyImageView.png"},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPicker/Customizing-Clipping#Customizing-Clipping-Shapes":{"type":"section","kind":"section","abstract":[{"text":"How to customize the clipping shape used by ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.technistic.ImageDataPicker\/documentation\/ImageDataPicker\/ImageDataPickerView","isActive":true},{"text":".","type":"text"}],"title":"Customizing Clipping Shapes","url":"\/tutorials\/imagedatapicker\/customizing-clipping#Customizing-Clipping-Shapes","identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPicker\/Customizing-Clipping#Customizing-Clipping-Shapes","role":"pseudoSymbol"},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPicker/Building-ListView#Add-the-MyImageListView":{"url":"\/tutorials\/imagedatapicker\/building-listview#Add-the-MyImageListView","type":"section","identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPicker\/Building-ListView#Add-the-MyImageListView","abstract":[{"text":"Create a ","type":"text"},{"type":"codeVoice","code":"List"},{"text":" view within a ","type":"text"},{"type":"codeVoice","code":"NavigationSplitView"},{"text":" to display the ","type":"text"},{"inlineContent":[{"text":"List","type":"text"}],"type":"strong"},{"text":" of Images and navigate to a ","type":"text"},{"inlineContent":[{"type":"text","text":"Detail"}],"type":"strong"},{"text":" view for each one .","type":"text"}],"kind":"section","title":"Add the MyImageListView","role":"pseudoSymbol"},"5-6-MyImageViewSrc.png":{"type":"image","variants":[{"url":"\/images\/com.technistic.ImageDataPicker\/5-6-MyImageViewSrc.png","traits":["1x","light"]}],"alt":"Xcode Framework Embed","identifier":"5-6-MyImageViewSrc.png"},"5-6-MyImageView.swift":{"content":["\/\/","\/\/  MyImageView.swift","\/\/  MyImageList","\/\/","\/\/  Copyright © 2025 Technistic Pty Ltd.","\/\/  Refer to LICENSE file for licensing terms.","\/\/","","import ImageDataPicker","import SwiftData","import SwiftUI","","struct MyImageView: View {","    @Environment(\\.modelContext) private var modelContext","","    @Binding public var selectedImageID: MyImage.ID?","    @State private var myImage: MyImage?","","    @State private var imageName: String = \"\"","    @State private var imageData: Data? = nil","","    var body: some View {","        HStack {","            Spacer()","            ","            VStack {","                Section(header: Text(\"Selected Image\")) {","                    VStack {","                        ImageDataPickerView(imageData: $imageData)","                            .frame(width: 120, height: 120)","                        ","                        TextField(\"Enter Image Name\", text: $imageName)","                            .textFieldStyle(.roundedBorder)","                            .multilineTextAlignment(.center)","                    }","                    .padding(20)","                    .background(.blue.opacity(0.6))","                    .cornerRadius(12)","                    ","                    HStack {","                        Button(role: .cancel) {","                            cancelChanges()","                        } label: {","                            Text(\"Cancel\")","                                .frame(maxWidth: .infinity)","                        }","                        .buttonStyle(.bordered)","","                        Button {","                            saveImage()","                        } label: {","                            Text(\"Save\")","                                .frame(maxWidth: .infinity)","                        }","                        .disabled(!hasChanges)","                        .buttonStyle(.bordered)","                    }","                }","                .padding(12)","                ","                Spacer()","            }","            ","            Spacer()","        }","        .frame(width: 360)","        .onAppear {","            loadSelectedImage()","        }","    }","","    private var hasChanges: Bool {","        guard let myImage = myImage else { return false }","        return imageName != myImage.imageName || imageData != myImage.imageData","    }","","    private func loadSelectedImage() {","        guard let selectedImageID = selectedImageID else { return }","        ","        myImage = modelContext.registeredModel(for: selectedImageID)","        ","        if let myImage = myImage {","            imageName = myImage.imageName","            imageData = myImage.imageData","        }","    }","","    private func cancelChanges() {","        guard let myImage = myImage else { return }","        ","        imageName = myImage.imageName","        imageData = myImage.imageData","        modelContext.rollback()","        selectedImageID = nil","    }","","    private func saveImage() {","        guard let myImage = myImage else { return }","        ","        myImage.imageName = imageName","        myImage.imageData = imageData","        ","        do {","            try modelContext.save()","        } catch {","            print(\"Error: \\(error.localizedDescription)\")","        }","        ","        selectedImageID = nil","    }","}","","#Preview {","    @Previewable @State var selectedImageID: MyImage.ID? = nil","    MyImageView(selectedIm