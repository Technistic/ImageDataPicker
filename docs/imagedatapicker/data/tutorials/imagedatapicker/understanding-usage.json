ation\/ImageDataPicker\/ImageDataPickerView","type":"topic","abstract":[{"type":"text","text":"The ImageDataPickerView is a SwiftUI view that allows users to select and display an image from their photo library. It represents a thumbnail image that can be changed or removed. If no image is selected, a placeholder image is displayed. The placeholder image can be changed to any SF system image. The image will also change to a Progress view while an image is loading or a Failure image if the transfer is unsuccessful. The Failure image can also be customised to any SF system image."}],"url":"\/documentation\/imagedatapicker\/imagedatapickerview","kind":"symbol","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ImageDataPickerView","kind":"identifier"}],"navigatorTitle":[{"text":"ImageDataPickerView","kind":"identifier"}],"title":"ImageDataPickerView"},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPicker/Starting-Extract#Extracting-the-Archive":{"abstract":[{"text":"Expand the downloaded Framework Archive.","type":"text"}],"identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPicker\/Starting-Extract#Extracting-the-Archive","role":"pseudoSymbol","kind":"section","url":"\/tutorials\/imagedatapicker\/starting-extract#Extracting-the-Archive","type":"section","title":"Extracting the Archive"},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPickerTOC/Releasing-Your-App":{"kind":"article","identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPickerTOC\/Releasing-Your-App","abstract":[],"url":"\/tutorials\/imagedatapickertoc\/releasing-your-app","type":"topic","role":"article","title":"Releasing Your App"},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPicker/Building-CreateProject#Add-the-Framework-to-your-Project":{"title":"Add the Framework to your Project","identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPicker\/Building-CreateProj