UI view that allows users to select and display an image from their photo library. The data associated with the selected photo is bound to an ","type":"text"},{"code":"imageData","type":"codeVoice"},{"text":" property of type ","type":"text"},{"code":"Data?","type":"codeVoice"},{"text":",  to simplify integration with ","type":"text"},{"code":"SwiftData","type":"codeVoice"},{"text":". The View presents a thumbnail of the Image that can be changed or removed. If no Image is selected, a placeholder image is displayed. The placeholder image can be changed to any SF system image. The Image will also change to a Progress view while an image is loading or a Failure image if the transfer is unsuccessful. The Failure image can also be customised to any SF system image.","type":"text"}],"identifier":"doc:\/\/com.technistic.ImageDataPicker\/documentation\/ImageDataPicker\/ImageDataPickerView","navigatorTitle":[{"text":"ImageDataPickerView","kind":"identifier"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ImageDataPickerView","kind":"identifier"}],"kind":"symbol"},"doc://com.technistic.ImageDataPicker/documentation/ImageDataPicker/ImageDataPickerView/accessibilityRotor(_:entries:entryID:entryLabel:)-3q1ix":{"identifier":"doc:\/\/com.technistic.ImageDataPicker\/documentation\/ImageDataPicker\/ImageDataPickerView\/accessibilityRotor(_:entries:entryID:entryLabel:)-3q1ix","kind":"symbol","abstract":[],"url":"\/documentation\/imagedatapicker\/imagedatapickerview\/accessibilityrotor(_:entries:entryid:entrylabel:)-3q1ix","title":"accessibilityRotor(_:entries:entryID:entryLabel:)","type":"topic","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"accessibilityRotor","kind":"identifier"},{"text":"<","kind":"text"},{"text":"EntryModel","kind":"genericParameter"},{"text":", ","kind":"text"},{"text":"ID","kind":"genericParameter"},{"text":">(","kind":"text"},{"preciseIdentifier":"s:7SwiftUI24Accessibilit