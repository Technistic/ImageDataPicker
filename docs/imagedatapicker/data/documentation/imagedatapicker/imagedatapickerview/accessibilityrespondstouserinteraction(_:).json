. The Failure image can also be customised to any SF system image.","type":"text"}],"identifier":"doc:\/\/com.technistic.ImageDataPicker\/documentation\/ImageDataPicker\/ImageDataPickerView","navigatorTitle":[{"text":"ImageDataPickerView","kind":"identifier"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ImageDataPickerView","kind":"identifier"}],"kind":"symbol"}}}