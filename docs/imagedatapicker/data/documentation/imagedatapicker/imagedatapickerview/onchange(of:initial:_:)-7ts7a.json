ataPicker\/documentation\/ImageDataPicker\/ImageDataPickerView","role":"symbol","kind":"symbol","type":"topic","abstract":[{"type":"text","text":"The ImageDataPickerView is a SwiftUI view that allows users to select and display an image from their photo library. It represents a thumbnail image that can be changed or removed. If no image is selected, a placeholder image is displayed. The placeholder image can be changed to any SF system image. The image will also change to a Progress view while an image is loading or a Failure image if the transfer is unsuccessful. The Failure image can also be customised to any SF system image."}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ImageDataPickerView","kind":"identifier"}],"url":"\/documentation\/imagedatapicker\/imagedatapickerview","navigatorTitle":[{"text":"ImageDataPickerView","kind":"identifier"}],"title":"ImageDataPickerView"},"doc://com.technistic.ImageDataPicker/documentation/ImageDataPicker":{"type":"topic","role":"collection","title":"ImageDataPicker","abstract":[{"text":"A Framework for binding an Image to SwiftData with a control that allows you to select a photo from the PhotoLibrary using the PhotosUI ","type":"text"},{"code":"PhotosPicker","type":"codeVoice"},{"text":".","type":"text"}],"kind":"symbol","url":"\/documentation\/imagedatapicker","identifier":"doc:\/\/com.technistic.ImageDataPicker\/documentation\/ImageDataPicker"},"doc://com.technistic.ImageDataPicker/documentation/ImageDataPicker/ImageDataPickerView/onChange(of:initial:_:)-7ts7a":{"role":"symbol","title":"onChange(of:initial:_:)","url":"\/documentation\/imagedatapicker\/imagedatapickerview\/onchange(of:initial:_:)-7ts7a","abstract":[],"type":"topic","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"onChange"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"V"},{"kind":"text","text":">("},{"kind":"externalParam","text":"of"},{"kind":"text",