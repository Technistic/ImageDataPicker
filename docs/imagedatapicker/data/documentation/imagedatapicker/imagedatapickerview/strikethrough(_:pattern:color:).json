h":0,"major":0,"minor":3},"sections":[],"references":{"doc://com.technistic.ImageDataPicker/documentation/ImageDataPicker/ImageDataPickerView":{"identifier":"doc:\/\/com.technistic.ImageDataPicker\/documentation\/ImageDataPicker\/ImageDataPickerView","type":"topic","abstract":[{"type":"text","text":"The ImageDataPickerView is a SwiftUI view that allows users to select and display an image from their photo library. It represents a thumbnail image that can be changed or removed. If no image is selected, a placeholder image is displayed. The placeholder image can be changed to any SF system image. The image will also change to a Progress view while an image is loading or a Failure image if the transfer is unsuccessful. The Failure image can also be customised to any SF system image."}],"url":"\/documentation\/imagedatapicker\/imagedatapickerview","kind":"symbol","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ImageDataPickerView","kind":"identifier"}],"navigatorTitle":[{"text":"ImageDataPickerView","kind":"identifier"}],"title":"ImageDataPickerView"},"doc://com.technistic.ImageDataPicker/documentation/ImageDataPicker/ImageDataPickerView/strikethrough(_:pattern:color:)":{"type":"topic","kind":"symbol","role":"symbol","title":"strikethrough(_:pattern:color:)","identifier":"doc:\/\/com.technistic.ImageDataPicker\/documentation\/ImageDataPicker\/ImageDataPickerView\/strikethrough(_:pattern:color:)","url":"\/documentation\/imagedatapicker\/imagedatapickerview\/strikethrough(_:pattern:color:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"strikethrough","kind":"identifier"},{"text":"(","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"},{"text":", ","kind":"text"},{"text":"pattern","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Text","kind":"typeIdentifier","preciseIdentifier":"s:7SwiftUI4TextV"},{"text":".","kind":"text"},{"text":"LineStyle","k