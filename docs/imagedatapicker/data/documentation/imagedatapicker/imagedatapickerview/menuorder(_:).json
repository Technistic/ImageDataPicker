y SF system image."}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ImageDataPickerView","kind":"identifier"}],"url":"\/documentation\/imagedatapicker\/imagedatapickerview","navigatorTitle":[{"text":"ImageDataPickerView","kind":"identifier"}],"title":"ImageDataPickerView"},"doc://com.technistic.ImageDataPicker/documentation/ImageDataPicker/ImageDataPickerView/menuOrder(_:)":{"kind":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"menuOrder"},{"kind":"text","text":"("},{"preciseIdentifier":"s:7SwiftUI9MenuOrderV","kind":"typeIdentifier","text":"MenuOrder"},{"kind":"text","text":") -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"preciseIdentifier":"s:7SwiftUI4ViewP","kind":"typeIdentifier","text":"View"}],"url":"\/documentation\/imagedatapicker\/imagedatapickerview\/menuorder(_:)","abstract":[],"type":"topic","identifier":"doc:\/\/com.technistic.ImageDataPicker\/documentation\/ImageDataPicker\/ImageDataPickerView\/menuOrder(_:)","title":"menuOrder(_:)","role":"symbol"}}}