fer is unsuccessful. The Failure image can also be customised to any SF system image."}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ImageDataPickerView","kind":"identifier"}],"url":"\/documentation\/imagedatapicker\/imagedatapickerview","navigatorTitle":[{"text":"ImageDataPickerView","kind":"identifier"}],"title":"ImageDataPickerView"},"doc://com.technistic.ImageDataPicker/documentation/ImageDataPicker/ImageDataPickerView/badge(_:)-4gnh5":{"identifier":"doc:\/\/com.technistic.ImageDataPicker\/documentation\/ImageDataPicker\/ImageDataPickerView\/badge(_:)-4gnh5","url":"\/documentation\/imagedatapicker\/imagedatapickerview\/badge(_:)-4gnh5","abstract":[],"role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"badge","kind":"identifier"},{"text":"<","kind":"text"},{"text":"S","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"S","kind":"typeIdentifier"},{"text":"?) -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","kind":"typeIdentifier","preciseIdentifier":"s:7SwiftUI4ViewP"}],"type":"topic","title":"badge(_:)","kind":"symbol"}}}