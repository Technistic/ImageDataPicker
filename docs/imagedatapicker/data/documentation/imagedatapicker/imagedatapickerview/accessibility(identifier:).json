:"topic","abstract":[{"type":"text","text":"The ImageDataPickerView is a SwiftUI view that allows users to select and display an image from their photo library. It represents a thumbnail image that can be changed or removed. If no image is selected, a placeholder image is displayed. The placeholder image can be changed to any SF system image. The image will also change to a Progress view while an image is loading or a Failure image if the transfer is unsuccessful. The Failure image can also be customised to any SF system image."}],"url":"\/documentation\/imagedatapicker\/imagedatapickerview","kind":"symbol","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ImageDataPickerView","kind":"identifier"}],"navigatorTitle":[{"text":"ImageDataPickerView","kind":"identifier"}],"title":"ImageDataPickerView"},"doc://com.technistic.ImageDataPicker/documentation/ImageDataPicker":{"type":"topic","abstract":[{"text":"A Framework for binding an Image to SwiftData with a control that allows you to select a photo from the PhotoLibrary using the PhotosUI ","type":"text"},{"code":"PhotosPicker","type":"codeVoice"},{"text":".","type":"text"}],"title":"ImageDataPicker","kind":"symbol","identifier":"doc:\/\/com.technistic.ImageDataPicker\/documentation\/ImageDataPicker","role":"collection","url":"\/documentation\/imagedatapicker"},"doc://com.technistic.ImageDataPicker/documentation/ImageDataPicker/ImageDataPickerView/accessibility(identifier:)":{"identifier":"doc:\/\/com.technistic.ImageDataPicker\/documentation\/ImageDataPicker\/ImageDataPickerView\/accessibility(identifier:)","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"accessibility","kind":"identifier"},{"text":"(","kind":"text"},{"text":"identifier","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"},{"text":") -> ","kind":"text"},{"text":"ModifiedContent","kind":"t