 thumbnail image that can be changed or removed. If no image is selected, a placeholder image is displayed. The placeholder image can be changed to any SF system image. The image will also change to a Progress view while an image is loading or a Failure image if the transfer is unsuccessful. The Failure image can also be customised to any SF system image."}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ImageDataPickerView","kind":"identifier"}],"url":"\/documentation\/imagedatapicker\/imagedatapickerview","navigatorTitle":[{"text":"ImageDataPickerView","kind":"identifier"}],"title":"ImageDataPickerView"},"doc://com.technistic.ImageDataPicker/documentation/ImageDataPicker/ImageDataPickerView/mask(alignment:_:)":{"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"mask"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"Mask"},{"kind":"text","text":">("},{"kind":"externalParam","text":"alignment"},{"kind":"text","text":": "},{"text":"Alignment","preciseIdentifier":"s:7SwiftUI9AlignmentV","kind":"typeIdentifier"},{"text":", () -> ","kind":"text"},{"text":"Mask","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","preciseIdentifier":"s:7SwiftUI4ViewP","kind":"typeIdentifier"}],"identifier":"doc:\/\/com.technistic.ImageDataPicker\/documentation\/ImageDataPicker\/ImageDataPickerView\/mask(alignment:_:)","url":"\/documentation\/imagedatapicker\/imagedatapickerview\/mask(alignment:_:)","abstract":[],"title":"mask(alignment:_:)","type":"topic","role":"symbol","kind":"symbol"},"doc://com.technistic.ImageDataPicker/documentation/ImageDataPicker":{"type":"topic","role":"collection","title":"ImageDataPicker","abstract":[{"text":"A Framework for binding an Image to SwiftData with a control that allows you to select a photo from the PhotoLibrary using the PhotosUI ","type":"text"},{"code":"PhotosPicker",