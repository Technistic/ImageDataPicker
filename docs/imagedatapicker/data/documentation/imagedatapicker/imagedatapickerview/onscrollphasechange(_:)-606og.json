":[{"type":"text","text":"The ImageDataPickerView is a SwiftUI view that allows users to select and display an image from their photo library. It represents a thumbnail image that can be changed or removed. If no image is selected, a placeholder image is displayed. The placeholder image can be changed to any SF system image. The image will also change to a Progress view while an image is loading or a Failure image if the transfer is unsuccessful. The Failure image can also be customised to any SF system image."}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ImageDataPickerView","kind":"identifier"}],"url":"\/documentation\/imagedatapicker\/imagedatapickerview","navigatorTitle":[{"text":"ImageDataPickerView","kind":"identifier"}],"title":"ImageDataPickerView"},"doc://com.technistic.ImageDataPicker/documentation/ImageDataPicker/ImageDataPickerView/onScrollPhaseChange(_:)-606og":{"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"onScrollPhaseChange","kind":"identifier"},{"text":"((","kind":"text"},{"text":"ScrollPhase","kind":"typeIdentifier","preciseIdentifier":"s:7SwiftUI11ScrollPhaseO"},{"text":", ","kind":"text"},{"text":"ScrollPhase","kind":"typeIdentifier","preciseIdentifier":"s:7SwiftUI11ScrollPhaseO"},{"text":", ","kind":"text"},{"text":"ScrollPhaseChangeContext","kind":"typeIdentifier","preciseIdentifier":"s:7SwiftUI24ScrollPhaseChangeContextV"},{"text":") -> ","kind":"text"},{"text":"Void","kind":"typeIdentifier","preciseIdentifier":"s:s4Voida"},{"text":") -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","kind":"typeIdentifier","preciseIdentifier":"s:7SwiftUI4ViewP"}],"kind":"symbol","role":"symbol","abstract":[],"title":"onScrollPhaseChange(_:)","type":"topic","identifier":"doc:\/\/com.technistic.ImageDataPicker\/documentation\/ImageDataPicker\/ImageDataPickerView\/onScrollPhaseChange(_:)-606og","url":"\/documentation\/imagedatapicker\/imageda