                VStack {","                        ImageDataPickerView(imageData: $imageData)","                            .frame(width: 120, height: 120)","                        ","                        TextField(\"Enter Image Name\", text: $imageName)","                            .textFieldStyle(.roundedBorder)","                            .multilineTextAlignment(.center)","                    }","                    .padding(20)","                    .background(.blue.opacity(0.6))","                    .cornerRadius(12)","                    ","                    HStack {","                        Button(role: .cancel) {","                            cancelChanges()","                        } label: {","                            Text(\"Cancel\")","                                .frame(maxWidth: .infinity)","                        }","                        .buttonStyle(.bordered)","","                        Button {","                            saveImage()","                        } label: {","                            Text(\"Save\")","                                .frame(maxWidth: .infinity)","                        }","                        .disabled(!hasChanges)","                        .buttonStyle(.bordered)","                    }","                }","                .padding(12)","                ","                Spacer()","            }","            ","            Spacer()","        }","        .frame(width: 360)","        .onAppear {","            loadSelectedImage()","        }","    }","","    private var hasChanges: Bool {","        guard let myImage = myImage else { return false }","        return imageName != myImage.imageName || imageData != myImage.imageData","    }","","    private func loadSelectedImage() {","        guard let selectedImageID = selectedImageID else { return }","        ","        myImage = modelContext.registeredModel(for: selectedImageID)","        ","        if let myImage = myImage {","            imageName = myImage.imageName","            imageData = myImage.imageData","        }","    }","","    private func cancelChanges() {","        guard let myImage = myImage else { return }","        ","        imageName = myImage.imageName","        imageData = myImage.imageData","        modelContext.rollback()","        selectedImageID = nil","    }","","    private func saveImage() {","        guard let myImage = myImage else { return }","        ","        myImage.imageName = imageName","        myImage.imageData = imageData","        ","        do {","            try modelContext.save()","        } catch {","            print(\"Error: \\(error.localizedDescription)\")","        }","        ","        selectedImageID = nil","    }","}","","#Preview {","    @Previewable @State var selectedImageID: MyImage.ID? = nil","    MyImageView(selectedImageID: $selectedImageID)","}"],"identifier":"5-6-MyImageView.swift","syntax":"swift","type":"file","fileType":"swift","fileName":"MyImageView.swift","highlights":[{"line":39},{"line":40},{"line":41},{"line":42},{"line":43},{"line":44},{"line":45},{"line":46},{"line":47},{"line":48},{"line":49},{"line":50},{"line":51},{"line":52},{"line":53},{"line":54},{"line":55},{"line":56},{"line":57},{"line":85},{"line":86},{"line":87},{"line":88},{"line":89},{"line":90},{"line":91},{"line":92},{"line":93},{"line":94},{"line":95},{"line":96},{"line":97},{"line":98},{"line":99},{"line":100},{"line":101},{"line":102},{"line":103},{"line":104},{"line":105},{"line":106},{"line":108},{"line":109}]},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPickerTOC":{"abstract":[{"text":"Learn how to install the framework, incorporate it in your app, and prepare a shipping build for release.","type":"text"}],"identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPickerTOC","title":"Using the ImageDataPicker Framework","role":"overview","kind":"overview","url":"\/tutorials\/imagedatapickertoc","type":"topic"},"doc://com.tech