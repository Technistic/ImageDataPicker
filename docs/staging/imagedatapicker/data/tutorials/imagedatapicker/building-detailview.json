ier":"5-4-MyImageView.swift","syntax":"swift","fileName":"MyImageView.swift","content":["\/\/","\/\/  MyImageView.swift","\/\/  MyImageList","\/\/","\/\/  Copyright © 2025 Technistic Pty Ltd.","\/\/  Refer to LICENSE file for licensing terms.","\/\/","","import ImageDataPicker","import SwiftData","import SwiftUI","","struct MyImageView: View {","    @Environment(\\.modelContext) private var modelContext","","    @Binding public var selectedImageID: MyImage.ID?","    @State private var myImage: MyImage?","","    @State private var imageName: String = \"\"","    @State private var imageData: Data? = nil","","    var body: some View {","        HStack {","            Spacer()","            ","            VStack {","                Section(header: Text(\"Selected Image\")) {","                    VStack {","                        ImageDataPickerView(imageData: $imageData)","                            .frame(width: 120, height: 120)","                        ","                        TextField(\"Enter Image Name\", text: $imageName)","                            .textFieldStyle(.roundedBorder)","                            .multilineTextAlignment(.center)","                    }","                    .padding(20)","                    .background(.blue.opacity(0.6))","                    .cornerRadius(12)","                }","                .padding(12)","                ","                Spacer()","            }","            ","            Spacer()","        }","        .frame(width: 360)","        .onAppear {","            loadSelectedImage()","        }","    }","","    private func loadSelectedImage() {","        guard let selectedImageID = selectedImageID else { return }","        ","        myImage = modelContext.registeredModel(for: selectedImageID)","        ","        if let myImage = myImage {","            imageName = myImage.imageName","            imageData = myImage.imageData","        }","    }","","}","","#Preview {","    @Previewable @State var selectedImageID: MyImage.ID? = nil","    MyImageView(selectedImageID: $selectedImageID)","}"],"fileType":"swift"},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPicker/Understanding-Usage":{"kind":"article","type":"topic","url":"\/tutorials\/imagedatapicker\/understanding-usage","title":"Using the Framework","identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPicker\/Understanding-Usage","abstract":[{"type":"text","text":"It is simple to incorporate the "},{"type":"strong","inlineContent":[{"text":"ImageDataPicker Framework","type":"text"}]},{"type":"text","text":" in your application. Add the package with Swift Package Manager or embed the xcframework, create a SwiftData model or "},{"type":"codeVoice","code":"@State"},{"type":"text","text":" property, and bind "},{"type":"reference","identifier":"doc:\/\/com.technistic.ImageDataPicker\/documentation\/ImageDataPicker\/ImageDataPickerView","isActive":true},{"type":"text","text":" to a "},{"type":"codeVoice","code":"Data?"},{"type":"text","text":" value."}],"role":"article","estimatedTime":"5min"},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPicker/Customizing-Placeholders":{"identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPicker\/Customizing-Placeholders","type":"topic","abstract":[{"text":"How to customize placeholder images in the ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.technistic.ImageDataPicker\/documentation\/ImageDataPicker\/ImageDataPickerView"},{"text":".","type":"text"}],"title":"Customizing Placeholder Images","role":"project","estimatedTime":"10min","kind":"project","url":"\/tutorials\/imagedatapicker\/customizing-placeholders"},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPickerTOC":{"title":"Using the ImageDataPicker Framework","kind":"overview","abstract":[{"type":"text","text":"Learn how to install the framework, incorporate it in your app, and prepare a shipping build for release."}],