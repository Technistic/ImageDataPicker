rong","inlineContent":[{"text":"Detail","type":"text"}]},{"text":" view for each one .","type":"text"}],"estimatedTime":"10min","identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPicker\/Building-ListView","type":"topic","kind":"project","role":"project"},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPicker/Starting-AddFramework#Add-with-Swift-Package-Manager":{"url":"\/tutorials\/imagedatapicker\/starting-addframework#Add-with-Swift-Package-Manager","title":"Add with Swift Package Manager","abstract":[{"type":"text","text":"How to add the ImageDataPicker framework to your project, either through Swift Package Manager or as a downloaded xcframework."}],"identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPicker\/Starting-AddFramework#Add-with-Swift-Package-Manager","type":"section","kind":"section","role":"pseudoSymbol"},"5-MyImageView.png":{"identifier":"5-MyImageView.png","variants":[{"traits":["1x","light"],"url":"\/images\/com.technistic.ImageDataPicker\/5-MyImageView@1x.png"},{"traits":["2x","light"],"url":"\/images\/com.technistic.ImageDataPicker\/5-MyImageView@2x.png"}],"alt":"List Background","type":"image"},"5-1-NewViewFile.png":{"type":"image","variants":[{"url":"\/images\/com.technistic.ImageDataPicker\/5-1-NewViewFile.png","traits":["1x","light"]}],"alt":"Xcode Framework Embed","identifier":"5-1-NewViewFile.png"},"5-2-NewViewFile-MyImageView.png":{"type":"image","identifier":"5-2-NewViewFile-MyImageView.png","alt":"Xcode Framework Embed","variants":[{"traits":["1x","light"],"url":"\/images\/com.technistic.ImageDataPicker\/5-2-NewViewFile-MyImageView.png"}]},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPicker/Building-ListView#Add-the-MyImageListView":{"kind":"section","url":"\/tutorials\/imagedatapicker\/building-listview#Add-the-MyImageListView","title":"Add the MyImageListView","abstract":[{"type":"text","text":"Create a "},{"type":"codeVoice","code":"List"},{"type":"text","text":" view within a "},{"type":"codeVoice","code":"NavigationSplitView"},{"type":"text","text":" to display the "},{"type":"strong","inlineContent":[{"text":"List","type":"text"}]},{"type":"text","text":" of Images and navigate to a "},{"type":"strong","inlineContent":[{"text":"Detail","type":"text"}]},{"type":"text","text":" view for each one ."}],"type":"section","identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPicker\/Building-ListView#Add-the-MyImageListView","role":"pseudoSymbol"},"5-7-MyImageListView.swift":{"type":"file","highlights":[{"line":13},{"line":14},{"line":15},{"line":52},{"line":54},{"line":55},{"line":104},{"line":105},{"line":106},{"line":107},{"line":108},{"line":109},{"line":110},{"line":111},{"line":112},{"line":114},{"line":121}],"identifier":"5-7-MyImageListView.swift","syntax":"swift","fileName":"MyImageListView.swift","content":["\/\/","\/\/  MyImageListView.swift","\/\/  MyImageList","\/\/","\/\/  Copyright © 2025 Technistic Pty Ltd.","\/\/  Refer to LICENSE file for licensing terms.","\/\/","","import ImageDataPicker","import SwiftData","import SwiftUI","","let emptyPlaceholder = \"photo.fill\"","let failurePlaceholder = \"exclamationmark.triangle\"","","struct MyImageListView: View {","    @Environment(\\.dismiss) private var dismiss","    ","    @Environment(\\.modelContext) private var modelContext","    @Query private var myImages: [MyImage]","    ","    @State private var selectedImageID: MyImage.ID? = nil","    @State private var columnVisibility = NavigationSplitViewVisibility","        .doubleColumn","    ","    var body: some View {","        NavigationSplitView(columnVisibility: $columnVisibility) {","            List(selection: $selectedImageID) {","                ForEach(myImages) { myImage in","                    MyImageListRow(myImage: myImage)","                }","                .onDelete(perform: deleteMyImages)","            }","            .navigationTitle(\"My Images\")","            .environment(\\.defaultMinListRowHeight, 100)","#if os(macOS)","            .navigationSplitViewColumnWidth(min: 180, ideal: 200)","#endif","            .toolbar {","#if os(iOS)","                ToolbarItem(placement: .navigationBarTrailing) {","                    EditButton()","                }","#endif","                ToolbarItem {","                    Button(action: addImage) {","                        Label(\"Add Image\", systemImage: \"plus\")","                    }","                }","            }","        } detail: {","            if selectedImageID == nil {","                Text(\"Please select an image.\")","            } else {","                MyImageView(selectedImageID: $selectedImageID)","            }","        }","    }","    ","    \/\/\/ Add a new Image.","    \/\/\/ Initially imageData defaults to nil.","    private func addImage() {","        withAnimation {","            let newImage = MyImage(","                imageName: \"New Image\"","            )","            modelContext.insert(newImage)","            selectedImageID = newImage.persistentModelID","        }","    }","","    \/\/\/ Delete the selected Image.","    \/\/\/ - Parameter offsets: The index(es) of the rows to delete.","    private func deleteMyImages(offsets: IndexSet) {","        withAnimation {","            for index in offsets {","                let deletedImage = myImages[index]","                if deletedImage.persistentModelID == selectedImageID {","                    selectedImageID = nil","                }","                modelContext.delete(deletedImage)","                if modelContext.hasChanges {","                    do {","                        try modelContext.save()","                    }","                    catch {","                        print(\"Error: \\(error)\")","                    }","                }","            }","        }","    }","}","","\/\/ MyImageListRow","struct MyImageListRow: View {","    var myImage: MyImage?","","    var body: some View {","        @State var img: Data? = myImage?.imageData","        @State var state: ImageDataModel = ImageDataModel(imageData: img)","            ","        HStack {","            VStack {","                ImageStateView(","                    imageState: state.imageState, emptyPlaceholder: emptyPlaceholder","                )","                .foregroundColor(.white)","                .squareImageView(shape: Circle(), background: .green)","                .background(Color.blue)","            }","            .frame(width: 80, height: 80)","            Text(myImage!.imageName)","                .padding(4)","        }","    }","}","","#Preview {","    MyImageListView()","        .modelContainer(for: MyImage.self, inMemory: true)","}"],"fileType":"swift"},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPicker/Customizing-Placeholders#Customizing-Placeholder-Images":{"url":"\/tutorials\/imagedatapicker\/customizing-placeholders#Customizing-Placeholder-Images","title":"Customizing Placeholder Images","abstract":[{"type":"text","text":"How to customize placeholder images in the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.technistic.ImageDataPicker\/documentation\/ImageDataPicker\/ImageDataPickerView"},{"type":"text","text":"."}],"identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPicker\/Customizing-Placeholders#Customizing-Placeholder-Images","type":"section","kind":"section","role":"pseudoSymbol"},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPicker/Starting-Extract":{"identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPicker\/Starting-Extract","type":"topic","abstract":[{"type":"text","text":"Expand the downloaded Framework Archive."}],"title":"Extract the Archive","role":"project","estimatedTime":"5min","kind":"project","url":"\/tutorials\/imagedatapicker\/starting-extract"},"5-3-MyImageViewSrc.png":{"type":"image","identifier":"5-3-MyImageViewSrc.png","alt":"Xcode Fra