{"fileType":"swift","type":"file","content":["\/\/","\/\/  MyImageView.swift","\/\/  MyImageList","\/\/","\/\/  Copyright © 2025 Technistic Pty Ltd.","\/\/  Refer to LICENSE file for licensing terms.","\/\/","","import ImageDataPicker","import SwiftData","import SwiftUI","","struct MyImageView: View {","    @Environment(\\.modelContext) private var modelContext","","    @Binding public var selectedImageID: MyImage.ID?","    @State private var myImage: MyImage?","","    @State private var imageName: String = \"\"","    @State private var imageData: Data? = nil","","    var body: some View {","        HStack {","            Spacer()","            ","            VStack {","                Section(header: Text(\"Selected Image\")) {","                    VStack {","                        ImageDataPickerView(imageData: $imageData)","                            .frame(width: 120, height: 120)","                        ","                        TextField(\"Enter Image Name\", text: $imageName)","                            .textFieldStyle(.roundedBorder)","                            .multilineTextAlignment(.center)","                    }","                    .padding(20)","                    .background(.blue.opacity(0.6))","                    .cornerRadius(12)","                ","                }","                .padding(12)","                ","                Spacer()","            }","            ","            Spacer()","        }","        .frame(width: 360)","        .onAppear {","            loadSelectedImage()","        }","    }","","    private var hasChanges: Bool {","        guard let myImage = myImage else { return false }","        return imageName != myImage.imageName || imageData != myImage.imageData","    }","","    private func loadSelectedImage() {","        guard let selectedImageID = selectedImageID else { return }","        ","        myImage = modelContext.registeredModel(for: selectedImageID)","        ","        if let myImage = myImage {","            imageName = myImage.imageName","            imageData = myImage.imageData","        }","    }","}","","#Preview {","    @Previewable @State var selectedImageID: MyImage.ID? = nil","    MyImageView(selectedImageID: $selectedImageID)","}"],"syntax":"swift","fileName":"MyImageView.swift","identifier":"5-5-MyImageView.swift","highlights":[{"line":39},{"line":54},{"line":55},{"line":56},{"line":57},{"line":58}]},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPicker/Understanding-Usage":{"role":"article","type":"topic","kind":"article","title":"Using the Framework","estimatedTime":"5min","url":"\/tutorials\/imagedatapicker\/understanding-usage","abstract":[{"text":"It is simple to incorporate the ","type":"text"},{"inlineContent":[{"type":"text","text":"ImageDataPicker Framework"}],"type":"strong"},{"text":" in your application. Add the package with Swift Package Manager or embed the xcframework, create a SwiftData model or ","type":"text"},{"type":"codeVoice","code":"@State"},{"text":" property, and bind ","type":"text"},{"identifier":"doc:\/\/com.technistic.ImageDataPicker\/documentation\/ImageDataPicker\/ImageDataPickerView","isActive":true,"type":"reference"},{"text":" to a ","type":"text"},{"type":"codeVoice","code":"Data?"},{"text":" value.","type":"text"}],"identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPicker\/Understanding-Usage"},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPicker/Customizing-Clipping":{"estimatedTime":"10min","abstract":[{"text":"How to customize the clipping shape used by ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.technistic.ImageDataPicker\/documentation\/ImageDataPicker\/ImageDataPickerView","isActive":true},{"text":".","type":"text"}],"url":"\/tutorials\/imagedatapicker\/customizing-clipping","title":"Customizing Clipping Options","kind":"project","type":"topic","identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPicker\/Customizing-Cl