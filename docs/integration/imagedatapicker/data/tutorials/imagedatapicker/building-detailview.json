    .frame(maxWidth: .infinity)","                        }","                        .disabled(!hasChanges)","                        .buttonStyle(.bordered)","                    }","                }","                .padding(12)","                ","                Spacer()","            }","            ","            Spacer()","        }","        .frame(width: 360)","        .onAppear {","            loadSelectedImage()","        }","    }","","    private var hasChanges: Bool {","        guard let myImage = myImage else { return false }","        return imageName != myImage.imageName || imageData != myImage.imageData","    }","","    private func loadSelectedImage() {","        guard let selectedImageID = selectedImageID else { return }","        ","        myImage = modelContext.registeredModel(for: selectedImageID)","        ","        if let myImage = myImage {","            imageName = myImage.imageName","            imageData = myImage.imageData","        }","    }","","    private func cancelChanges() {","        guard let myImage = myImage else { return }","        ","        imageName = myImage.imageName","        imageData = myImage.imageData","        modelContext.rollback()","        selectedImageID = nil","    }","","    private func saveImage() {","        guard let myImage = myImage else { return }","        ","        myImage.imageName = imageName","        myImage.imageData = imageData","        ","        do {","            try modelContext.save()","        } catch {","            print(\"Error: \\(error.localizedDescription)\")","        }","        ","        selectedImageID = nil","    }","}","","#Preview {","    @Previewable @State var selectedImageID: MyImage.ID? = nil","    MyImageView(selectedImageID: $selectedImageID)","}"],"highlights":[{"line":39},{"line":40},{"line":41},{"line":42},{"line":43},{"line":44},{"line":45},{"line":46},{"line":47},{"line":48},{"line":49},{"line":50},{"line":51},{"line":52},{"line":53},{"line":54},{"line"