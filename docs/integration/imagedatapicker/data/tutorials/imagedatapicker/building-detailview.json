 latest version of the "},{"inlineContent":[{"type":"text","text":"ImageDataPicker"}],"type":"strong"},{"type":"text","text":" framework from the official repository."},{"type":"text","text":" "},{"type":"text","text":"Extract the archive and add the Framework to your Xcode project."}],"url":"\/tutorials\/imagedatapicker\/starting-download#Download-the-Framework"},"5-6-MyImageViewSrc.png":{"variants":[{"url":"\/images\/com.technistic.ImageDataPicker\/5-6-MyImageViewSrc.png","traits":["1x","light"]}],"type":"image","alt":"Xcode Framework Embed","identifier":"5-6-MyImageViewSrc.png"},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPicker/Releasing-Entitlements#Configure-Entitlements":{"role":"pseudoSymbol","url":"\/tutorials\/imagedatapicker\/releasing-entitlements#Configure-Entitlements","abstract":[{"type":"text","text":"Review the following runtime permissions before distributing an app that uses ImageDataPicker."}],"type":"section","identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPicker\/Releasing-Entitlements#Configure-Entitlements","title":"Configure Entitlements","kind":"section"},"5-5-MyImageViewSrc.png":{"alt":"Xcode Framework Embed","variants":[{"url":"\/images\/com.technistic.ImageDataPicker\/5-5-MyImageViewSrc.png","traits":["1x","light"]}],"type":"image","identifier":"5-5-MyImageViewSrc.png"},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPicker/Releasing-Signing#Verify-App-Signing":{"identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPicker\/Releasing-Signing#Verify-App-Signing","role":"pseudoSymbol","kind":"section","title":"Verify App Signing","url":"\/tutorials\/imagedatapicker\/releasing-signing#Verify-App-Signing","abstract":[{"type":"text","text":"Review the following aspects of your app before distribution when using the xcframework form of ImageDataPicker."}],"type":"section"},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPickerTOC/Understanding-the-Framework":{"identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPickerTOC\/Understanding-the-Framework","kind":"article","role":"article","type":"topic","title":"Understanding the Framework","abstract":[],"url":"\/tutorials\/imagedatapickertoc\/understanding-the-framework"},"5-7-MyImageListView.swift":{"highlights":[{"line":13},{"line":14},{"line":15},{"line":52},{"line":54},{"line":55},{"line":104},{"line":105},{"line":106},{"line":107},{"line":108},{"line":109},{"line":110},{"line":111},{"line":112},{"line":114},{"line":121}],"type":"file","identifier":"5-7-MyImageListView.swift","syntax":"swift","fileName":"MyImageListView.swift","content":["\/\/","\/\/  MyImageListView.swift","\/\/  MyImageList","\/\/","\/\/  Copyright © 2025 Technistic Pty Ltd.","\/\/  Refer to LICENSE file for licensing terms.","\/\/","","import ImageDataPicker","import SwiftData","import SwiftUI","","let emptyPlaceholder = \"photo.fill\"","let failurePlaceholder = \"exclamationmark.triangle\"","","struct MyImageListView: View {","    @Environment(\\.dismiss) private var dismiss","    ","    @Environment(\\.modelContext) private var modelContext","    @Query private var myImages: [MyImage]","    ","    @State private var selectedImageID: MyImage.ID? = nil","    @State private var columnVisibility = NavigationSplitViewVisibility","        .doubleColumn","    ","    var body: some View {","        NavigationSplitView(columnVisibility: $columnVisibility) {","            List(selection: $selectedImageID) {","                ForEach(myImages) { myImage in","                    MyImageListRow(myImage: myImage)","                }","                .onDelete(perform: deleteMyImages)","            }","            .navigationTitle(\"My Images\")","            .environment(\\.defaultMinListRowHeight, 100)","#if os(macOS)","            .navigationSplitViewColumnWidth(min: 180, ideal: 200)","#endif","            .toolbar {","#if os(iOS)","                ToolbarItem(placement: .navigationBarTrailing) {","                    EditButton()","                }","#endif","                ToolbarItem {","                    Button(action: addImage) {","                        Label(\"Add Image\", systemImage: \"plus\")","                    }","                }","            }","        } detail: {","            if selectedImageID == nil {","                Text(\"Please select an image.\")","            } else {","                MyImageView(selectedImageID: $selectedImageID)","            }","        }","    }","    ","    \/\/\/ Add a new Image.","    \/\/\/ Initially imageData defaults to nil.","    private func addImage() {","        withAnimation {","            let newImage = MyImage(","                imageName: \"New Image\"","            )","            modelContext.insert(newImage)","            selectedImageID = newImage.persistentModelID","        }","    }","","    \/\/\/ Delete the selected Image.","    \/\/\/ - Parameter offsets: The index(es) of the rows to delete.","    private func deleteMyImages(offsets: IndexSet) {","        withAnimation {","            for index in offsets {","                let deletedImage = myImages[index]","                if deletedImage.persistentModelID == selectedImageID {","                    selectedImageID = nil","                }","                modelContext.delete(deletedImage)","                if modelContext.hasChanges {","                    do {","                        try modelContext.save()","                    }","                    catch {","                        print(\"Error: \\(error)\")","                    }","                }","            }","        }","    }","}","","\/\/ MyImageListRow","struct MyImageListRow: View {","    var myImage: MyImage?","","    var body: some View {","        @State var img: Data? = myImage?.imageData","        @State var state: ImageDataModel = ImageDataModel(imageData: img)","            ","        HStack {","            VStack {","                ImageStateView(","                    imageState: state.imageState, emptyPlaceholder: emptyPlaceholder","                )","                .foregroundColor(.white)","                .squareImageView(shape: Circle(), background: .green)","                .background(Color.blue)","            }","            .frame(width: 80, height: 80)","            Text(myImage!.imageName)","                .padding(4)","        }","    }","}","","#Preview {","    MyImageListView()","        .modelContainer(for: MyImage.self, inMemory: true)","}"],"fileType":"swift"}}}