2},{"line":43},{"line":44},{"line":45},{"line":46},{"line":47},{"line":48},{"line":49},{"line":50},{"line":51},{"line":52},{"line":53},{"line":54},{"line":55},{"line":56},{"line":57},{"line":58},{"line":59},{"line":60},{"line":61},{"line":63},{"line":67},{"line":68}],"content":["\/\/","\/\/  MyImageView.swift","\/\/  MyImageList","\/\/","\/\/  Copyright © 2025 Technistic Pty Ltd.","\/\/  Refer to LICENSE file for licensing terms.","\/\/","","import ImageDataPicker","import SwiftData","import SwiftUI","","struct MyImageView: View {","    @Environment(\\.modelContext) private var modelContext","","    @Binding public var selectedImageID: MyImage.ID?","    @State private var myImage: MyImage?","","    @State private var imageName: String = \"\"","    @State private var imageData: Data? = nil","","    var body: some View {","        HStack {","            Spacer()","            ","            VStack {","                Section(header: Text(\"Selected Image\")) {","                    VStack {","                        ImageDataPickerView(imageData: $imageData)","                            .frame(width: 120, height: 120)","                        ","                        TextField(\"Enter Image Name\", text: $imageName)","                            .textFieldStyle(.roundedBorder)","                            .multilineTextAlignment(.center)","                    }","                    .padding(20)","                    .background(.blue.opacity(0.6))","                    .cornerRadius(12)","                }","                .padding(12)","                ","                Spacer()","            }","            ","            Spacer()","        }","        .frame(width: 360)","        .onAppear {","            loadSelectedImage()","        }","    }","","    private func loadSelectedImage() {","        guard let selectedImageID = selectedImageID else { return }","        ","        myImage = modelContext.registeredModel(for: selectedImageID)","        ","        if let myImage = myImage {","            imageName = myImage.imageName","            imageData = myImage.imageData","        }","    }","","}","","#Preview {","    @Previewable @State var selectedImageID: MyImage.ID? = nil","    MyImageView(selectedImageID: $selectedImageID)","}"],"identifier":"5-4-MyImageView.swift","fileType":"swift","syntax":"swift"},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPickerTOC":{"type":"topic","abstract":[{"type":"text","text":"Learn how to install the framework, incorporate it in your app, and prepare a shipping build for release."}],"title":"Using the ImageDataPicker Framework","kind":"overview","url":"\/tutorials\/imagedatapickertoc","role":"overview","identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPickerTOC"},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPicker/Building-DataModel":{"role":"project","url":"\/tutorials\/imagedatapicker\/building-datamodel","kind":"project","identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPicker\/Building-DataModel","abstract":[{"type":"text","text":"Add a SwiftData Model to your project to store a list of images."}],"title":"Create a SwiftData Model","estimatedTime":"10min","type":"topic"},"5-3-MyImageViewSrc.png":{"identifier":"5-3-MyImageViewSrc.png","alt":"Xcode Framework Embed","type":"image","variants":[{"traits":["1x","light"],"url":"\/images\/com.technistic.ImageDataPicker\/5-3-MyImageViewSrc.png"}]},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPicker/Starting-Download#Download-the-Framework":{"abstract":[{"text":"Download the latest version of the ","type":"text"},{"inlineContent":[{"type":"text","text":"ImageDataPicker"}],"type":"strong"},{"text":" framework from the official repository.","type":"text"},{"text":" ","type":"text"},{"text":"Extract the archive and add the Framework to your Xcode project.","type":"text"}],"role":"pseudoSymbol","title":"Download the Framework","url":"\/tutorials\/imagedatapicker\/starting-download#Download-the-Framework","type":"section","identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPicker\/Starting-Download#Download-the-Framework","kind":"section"},"5-7-MyImageListView.swift":{"highlights":[{"line":13},{"line":14},{"line":15},{"line":52},{"line":54},{"line":55},{"line":104},{"line":105},{"line":106},{"line":107},{"line":108},{"line":109},{"line":110},{"line":111},{"line":112},{"line":114},{"line":121}],"identifier":"5-7-MyImageListView.swift","fileName":"MyImageListView.swift","type":"file","content":["\/\/","\/\/  MyImageListView.swift","\/\/  MyImageList","\/\/","\/\/  Copyright © 2025 Technistic Pty Ltd.","\/\/  Refer to LICENSE file for licensing terms.","\/\/","","import ImageDataPicker","import SwiftData","import SwiftUI","","let emptyPlaceholder = \"photo.fill\"","let failurePlaceholder = \"exclamationmark.triangle\"","","struct MyImageListView: View {","    @Environment(\\.dismiss) private var dismiss","    ","    @Environment(\\.modelContext) private var modelContext","    @Query private var myImages: [MyImage]","    ","    @State private var selectedImageID: MyImage.ID? = nil","    @State private var columnVisibility = NavigationSplitViewVisibility","        .doubleColumn","    ","    var body: some View {","        NavigationSplitView(columnVisibility: $columnVisibility) {","            List(selection: $selectedImageID) {","                ForEach(myImages) { myImage in","                    MyImageListRow(myImage: myImage)","                }","                .onDelete(perform: deleteMyImages)","            }","            .navigationTitle(\"My Images\")","            .environment(\\.defaultMinListRowHeight, 100)","#if os(macOS)","            .navigationSplitViewColumnWidth(min: 180, ideal: 200)","#endif","            .toolbar {","#if os(iOS)","                ToolbarItem(placement: .navigationBarTrailing) {","                    EditButton()","                }","#endif","                ToolbarItem {","                    Button(action: addImage) {","                        Label(\"Add Image\", systemImage: \"plus\")","                    }","                }","            }","        } detail: {","            if selectedImageID == nil {","                Text(\"Please select an image.\")","            } else {","                MyImageView(selectedImageID: $selectedImageID)","            }","        }","    }","    ","    \/\/\/ Add a new Image.","    \/\/\/ Initially imageData defaults to nil.","    private func addImage() {","        withAnimation {","            let newImage = MyImage(","                imageName: \"New Image\"","            )","            modelContext.insert(newImage)","            selectedImageID = newImage.persistentModelID","        }","    }","","    \/\/\/ Delete the selected Image.","    \/\/\/ - Parameter offsets: The index(es) of the rows to delete.","    private func deleteMyImages(offsets: IndexSet) {","        withAnimation {","            for index in offsets {","                let deletedImage = myImages[index]","                if deletedImage.persistentModelID == selectedImageID {","                    selectedImageID = nil","                }","                modelContext.delete(deletedImage)","                if modelContext.hasChanges {","                    do {","                        try modelContext.save()","                    }","                    catch {","                        print(\"Error: \\(error)\")","                    }","                }","            }","        }","    }","}","","\/\/ MyImageListRow","struct MyImageListRow: View {","    var myImage: MyImage?","","    var body: some View {","        @State var img: Data? = myImage?.imageData","        @State var state: ImageDataModel = ImageDataModel(imageData: img)","            ","        HStack {","            VStack {","                ImageStateView(","                    imageState: state.imageState, emptyPlaceholder: emptyPlaceholder","                )","                .foregroundColor(.white)","                .squareImageView(shape: Circle(), background: .green)","                .background(Color.blue)","            }","            .frame(width: 80, height: 80)","            Text(myImage!.imageName)","                .padding(4)","        }","    }","}","","#Preview {","    MyImageListView()","        .modelContainer(for: MyImage.self, inMemory: true)","}"],"fileType":"swift","syntax":"swift"},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPickerTOC/Understanding-the-Framework":{"type":"topic","kind":"article","title":"Understanding the Framework","url":"\/tutorials\/imagedatapickertoc\/understanding-the-framework","abstract":[],"role":"article","identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPickerTOC\/Understanding-the-Framework"},"Phone-Header-R.png":{"identifier":"Phone-Header-R.png","alt":"Phone Background","type":"image","variants":[{"url":"\/images\/com.technistic.ImageDataPicker\/Phone-Header-R@1x.png","traits":["1x","light"]},{"url":"\/images\/com.technistic.ImageDataPicker\/Phone-Header-R@2x.png","traits":["2x","light"]}]},"5-6-MyImageViewSrc.png":{"identifier":"5-6-MyImageViewSrc.png","alt":"Xcode Framework Embed","variants":[{"traits":["1x","light"],"url":"\/images\/com.technistic.ImageDataPicker\/5-6-MyImageViewSrc.png"}],"type":"image"},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPicker/Starting-Extract#Extracting-the-Archive":{"title":"Extracting the Archive","url":"\/tutorials\/imagedatapicker\/starting-extract#Extracting-the-Archive","identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPicker\/Starting-Extract#Extracting-the-Archive","kind":"section","type":"section","role":"pseudoSymbol","abstract":[{"type":"text","text":"Expand the downloaded Framework Archive."}]},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPickerTOC/Building-an-ImageDataPicker-App":{"abstract":[],"kind":"article","tit