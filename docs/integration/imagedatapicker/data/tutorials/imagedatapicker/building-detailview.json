ImageDataPicker\/5-5-MyImageViewSrc.png","traits":["1x","light"]}],"type":"image","identifier":"5-5-MyImageViewSrc.png","alt":"Xcode Framework Embed"},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPicker/Starting-Extract":{"estimatedTime":"5min","kind":"project","type":"topic","title":"Extract the Archive","identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPicker\/Starting-Extract","url":"\/tutorials\/imagedatapicker\/starting-extract","abstract":[{"type":"text","text":"Expand the downloaded Framework Archive."}],"role":"project"},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPickerTOC/Releasing-Your-App":{"kind":"article","title":"Releasing Your App","role":"article","url":"\/tutorials\/imagedatapickertoc\/releasing-your-app","type":"topic","identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPickerTOC\/Releasing-Your-App","abstract":[]},"5-5-MyImageView.swift":{"content":["\/\/","\/\/  MyImageView.swift","\/\/  MyImageList","\/\/","\/\/  Copyright © 2025 Technistic Pty Ltd.","\/\/  Refer to LICENSE file for licensing terms.","\/\/","","import ImageDataPicker","import SwiftData","import SwiftUI","","struct MyImageView: View {","    @Environment(\\.modelContext) private var modelContext","","    @Binding public var selectedImageID: MyImage.ID?","    @State private var myImage: MyImage?","","    @State private var imageName: String = \"\"","    @State private var imageData: Data? = nil","","    var body: some View {","        HStack {","            Spacer()","            ","            VStack {","                Section(header: Text(\"Selected Image\")) {","                    VStack {","                        ImageDataPickerView(imageData: $imageData)","                            .frame(width: 120, height: 120)","                        ","                        TextField(\"Enter Image Name\", text: $imageName)","                            .textFieldStyle(.roundedBorder)","                            .multilineTextAlignment(.center)","                    }","                    .padding(20)","                    .background(.blue.opacity(0.6))","                    .cornerRadius(12)","                ","                }","                .padding(12)","                ","                Spacer()","            }","            ","            Spacer()","        }","        .frame(width: 360)","        .onAppear {","            loadSelectedImage()","        }","    }","","    private var hasChanges: Bool {","        guard let myImage = myImage else { return false }","        return imageName != myImage.imageName || imageData != myImage.imageData","    }","","    private func loadSelectedImage() {","        guard let selectedImageID = selectedImageID else { return }","        ","        myImage = modelContext.registeredModel(for: selectedImageID)","        ","        if let myImage = myImage {","            imageName = myImage.imageName","            imageData = myImage.imageData","        }","    }","}","","#Preview {","    @Previewable @State var selectedImageID: MyImage.ID? = nil","    MyImageView(selectedImageID: $selectedImageID)","}"],"highlights":[{"line":39},{"line":54},{"line":55},{"line":56},{"line":57},{"line":58}],"fileName":"MyImageView.swift","type":"file","fileType":"swift","identifier":"5-5-MyImageView.swift","syntax":"swift"},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPicker/Building-ListView#Add-a-NavigationSplitView":{"abstract":[{"text":"Create a ","type":"text"},{"type":"codeVoice","code":"List"},{"text":" view within a ","type":"text"},{"type":"codeVoice","code":"NavigationSplitView"},{"text":" to display the ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"List"}]},{"text":" of Images and navigate to a ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"Detail"}]},{"text":" view for each one .","type":"text"}],"role":"pseudoSymbol","type":"section","kind":"section","identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPicker\/Building-ListView#Add-a-NavigationSplitView","title":"Add a NavigationSplitView","url":"\/tutorials\/imagedatapicker\/building-listview#Add-a-NavigationSplitView"},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPicker/Understanding-Customization":{"title":"Customization Options","kind":"article","url":"\/tutorials\/imagedatapicker\/understanding-customization","type":"topic","identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPicker\/Understanding-Customization","role":"article","estimatedTime":"5min","abstract":[{"type":"text","text":"The "},{"inlineContent":[{"text":"ImageDataPicker Framework","type":"text"}],"type":"strong"},{"type":"text","text":" allows you to customize how the "},{"identifier":"doc:\/\/com.technistic.ImageDataPicker\/documentation\/ImageDataPicker\/ImageDataPickerView","isActive":true,"type":"reference"},{"type":"text","text":" appears. You have options to specify placeholder images, clipping shapes, and more to suit your application’s requirements."}]},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPicker/Building-DetailView":{"type":"topic","kind":"project","url":"\/tutorials\/imagedatapicker\/building-detailview","title":"Create a Detail view","identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPicker\/Building-DetailView","estimatedTime":"10min","role":"project","abstract":[{"type":"text","text":"Add a Detail view to your SwiftUI project that allows users to view and select images."}]},"5-7-MyImageListView.swift":{"content":["\/\/","\/\/  MyImageListView.swift","\/\/  MyImageList","\/\/","\/\/  Copyright © 2025 Technistic Pty Ltd.","\/\/  Refer to LICENSE file for licensing terms.","\/\/","","import ImageDataPicker","import SwiftData","import SwiftUI","","let emptyPlaceholder = \"photo.fill\"","let failurePlaceholder = \"exclamationmark.triangle\"","","struct MyImageListView: View {","    @Environment(\\.dismiss) private var dismiss","    ","    @Environment(\\.modelContext) private var modelContext","    @Query private var myImages: [MyImage]","    ","    @State private var selectedImageID: MyImage.ID? = nil","    @State private var columnVisibility = NavigationSplitViewVisibility","        .doubleColumn","    ","    var body: some View {","        NavigationSplitView(columnVisibility: $columnVisibility) {","            List(selection: $selectedImageID) {","                ForEach(myImages) { myImage in","                    MyImageListRow(myImage: myImage)","                }","                .onDelete(perform: deleteMyImages)","            }","            .navigationTitle(\"My Images\")","            .environment(\\.defaultMinListRowHeight, 100)","#if os(macOS)","            .navigationSplitViewColumnWidth(min: 180, ideal: 200)","#endif","            .toolbar {","#if os(iOS)","                ToolbarItem(placement: .navigationBarTrailing) {","                    EditButton()","                }","#endif","                ToolbarItem {","                    Button(action: addImage) {","                        Label(\"Add Image\", systemImage: \"plus\")","                    }","                }","            }","        } detail: {","            if selectedImageID == nil {","                Text(\"Please select an image.\")","            } else {","                MyImageView(selectedImageID: $selectedImageID)","            }","        }","    }","    ","    \/\/\/ Add a new Image.","    \/\/\/ Initially imageData defaults to nil.","    private func addImage() {","        withAnimation {","            let newImage = MyImage(","                imageName: \"New Image\"","            )","            modelContext.insert(newImage)","            selectedImageID = newImage.persistentModelID","        }","    }","","    \/\/\/ Delete the selected Image.","    \/\/\/ - Parameter offsets: The index(es) of the rows to delete.","    private func deleteMyImages(offsets: IndexSet) {","        withAnimation {","            for index in offsets {","                let deletedImage = myImages[index]","                if deletedImage.persistentModelID == selectedImageID {","                    selectedImageID = nil","                }","                modelContext.delete(deletedImage)","                if modelContext.hasChanges {","                    do {","                        try modelContext.save()","                    }","                    catch {","                        print(\"Error: \\(error)\")","                    }","                }","            }","        }","    }","}","","\/\/ MyImageListRow","struct MyImageListRow: View {","    var myImage: MyImage?","","    var body: some View {","        @State var img: Data? = myImage?.imageData","        @State var state: ImageDataModel = ImageDataModel(imageData: img)","            ","        HStack {","            VStack {","                ImageStateView(","                    imageState: state.imageState, emptyPlaceholder: emptyPlaceholder","                )","                .foregroundColor(.white)","                .squareImageView(shape: Circle(), background: .green)","                .background(Color.blue)","            }","            .frame(width: 80, height: 80)","            Text(myImage!.imageName)","                .padding(4)","        }","    }","}","","#Preview {","    MyImageListView()","        .modelContainer(for: MyImage.self, inMemory: true)","}"],"syntax":"swift","fileName":"MyImageListView.swift","identifier":"5-7-MyImageListView.swift","fileType":"swift","highlights":[{"line":13},{"line":14},{"line":15},{"line":52},{"line":54},{"line":55},{"line":104},{"line":105},{"line":106},{"line":107},{"line":108},{"line":109},{"line":110},{"line":111},{"line":112},{"line":114},{"line":121}],"type":"file"},"5-1-NewViewFile.png":{"type":"image","identifier":"5-1-NewViewFile.png","variants":[{"url":"\/images\/com.technistic.ImageDataPicker\/5-1-NewViewFile.png","tr