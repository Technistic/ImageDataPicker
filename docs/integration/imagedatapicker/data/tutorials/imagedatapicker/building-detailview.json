/imagedatapicker\/customizing-clipping#Customizing-Clipping-Shapes","title":"Customizing Clipping Shapes","type":"section","identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPicker\/Customizing-Clipping#Customizing-Clipping-Shapes","kind":"section","abstract":[{"type":"text","text":"How to customize the clipping shape used by "},{"type":"reference","identifier":"doc:\/\/com.technistic.ImageDataPicker\/documentation\/ImageDataPicker\/ImageDataPickerView","isActive":true},{"type":"text","text":"."}],"role":"pseudoSymbol"}}}