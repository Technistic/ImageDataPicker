c.png","traits":["1x","light"]}],"type":"image","alt":"Xcode Framework Embed","identifier":"5-3-MyImageViewSrc.png"},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPicker/Starting-AddFramework#Add-the-XCFramework-to-your-Project":{"type":"section","url":"\/tutorials\/imagedatapicker\/starting-addframework#Add-the-XCFramework-to-your-Project","kind":"section","abstract":[{"type":"text","text":"How to add the ImageDataPicker framework to your project, either through Swift Package Manager or as a downloaded xcframework."}],"title":"Add the XCFramework to your Project","identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPicker\/Starting-AddFramework#Add-the-XCFramework-to-your-Project","role":"pseudoSymbol"},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPicker/Understanding-Customization":{"type":"topic","url":"\/tutorials\/imagedatapicker\/understanding-customization","estimatedTime":"5min","kind":"article","abstract":[{"text":"The ","type":"text"},{"inlineContent":[{"type":"text","text":"ImageDataPicker Framework"}],"type":"strong"},{"text":" allows you to customize how the ","type":"text"},{"identifier":"doc:\/\/com.technistic.ImageDataPicker\/documentation\/ImageDataPicker\/ImageDataPickerView","isActive":true,"type":"reference"},{"text":" appears. You have options to specify placeholder images, clipping shapes, and more to suit your application’s requirements.","type":"text"}],"title":"Customization Options","identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPicker\/Understanding-Customization","role":"article"},"5-5-MyImageView.swift":{"fileType":"swift","content":["\/\/","\/\/  MyImageView.swift","\/\/  MyImageList","\/\/","\/\/  Copyright © 2025 Technistic Pty Ltd.","\/\/  Refer to LICENSE file for licensing terms.","\/\/","","import ImageDataPicker","import SwiftData","import SwiftUI","","struct MyImageView: View {","    @Environment(\\.modelContext) private var modelContext","","    @Binding public var selectedImageID: MyImage.ID?","    @State private var myImage: MyImage?","","    @State private var imageName: String = \"\"","    @State private var imageData: Data? = nil","","    var body: some View {","        HStack {","            Spacer()","            ","            VStack {","                Section(header: Text(\"Selected Image\")) {","                    VStack {","                        ImageDataPickerView(imageData: $imageData)","                            .frame(width: 120, height: 120)","                        ","                        TextField(\"Enter Image Name\", text: $imageName)","                            .textFieldStyle(.roundedBorder)","                            .multilineTextAlignment(.center)","                    }","                    .padding(20)","                    .background(.blue.opacity(0.6))","                    .cornerRadius(12)","                ","                }","                .padding(12)","                ","                Spacer()","            }","            ","            Spacer()","        }","        .frame(width: 360)","        .onAppear {","            loadSelectedImage()","        }","    }","","    private var hasChanges: Bool {","        guard let myImage = myImage else { return false }","        return imageName != myImage.imageName || imageData != myImage.imageData","    }","","    private func loadSelectedImage() {","        guard let selectedImageID = selectedImageID else { return }","        ","        myImage = modelContext.registeredModel(for: selectedImageID)","        ","        if let myImage = myImage {","            imageName = myImage.imageName","            imageData = myImage.imageData","        }","    }","}","","#Preview {","    @Previewable @State var selectedImageID: MyImage.ID? = nil","    MyImageView(selectedImageID: $selectedImageID)","}"],"identifier":"5-5-MyImageView.swift","highlights":[{"line":39},{"line":54},{"line":55},{"line":56},{"line":57},{"line":58}],"syntax":"swift","fileName":"MyImageView.swift","type":"file"},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPicker/Releasing-Signing#Verify-App-Signing":{"type":"section","url":"\/tutorials\/imagedatapicker\/releasing-signing#Verify-App-Signing","kind":"section","abstract":[{"type":"text","text":"Review the following aspects of your app before distribution when using the xcframework form of ImageDataPicker."}],"title":"Verify App Signing","identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPicker\/Releasing-Signing#Verify-App-Signing","role":"pseudoSymbol"},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPickerTOC/Understanding-the-Framework":{"kind":"article","identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPickerTOC\/Understanding-the-Framework","title":"Understanding the Framework","role":"article","abstract":[],"type":"topic","url":"\/tutorials\/imagedatapickertoc\/understanding-the-framework"},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPickerTOC/Releasing-Your-App":{"type":"topic","url":"\/tutorials\/imagedatapickertoc\/releasing-your-app","kind":"article","abstract":[],"title":"Releasing Your App","identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPickerTOC\/Releasing-Your-App","role":"article"},"5-5-MyImageViewSrc.png":{"alt":"Xcode Framework Embed","identifier":"5-5-MyImageViewSrc.png","variants":[{"url":"\/images\/com.technistic.ImageDataPicker\/5-5-MyImageViewSrc.png","traits":["1x","light"]}],"type":"image"},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPicker/Starting-AddFramework":{"type":"topic","url":"\/tutorials\/imagedatapicker\/starting-addframework","estimatedTime":"5min","kind":"project","abstract":[{"type":"text","text":"How to add the ImageDataPicker framework to your project, either through Swift Package Manager or as a downloaded xcframework."}],"title":"Add the ImageDataPicker Framework to your Project","identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPicker\/Starting-AddFramework","role":"project"},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPicker/Releasing-Entitlements":{"type":"topic","url":"\/tutorials\/imagedatapicker\/releasing-entitlements","estimatedTime":"5min","kind":"project","abstract":[{"type":"text","text":"Review the following runtime permissions before distributing an app that uses ImageDataPicker."}],"title":"App Entitlements","identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPicker\/Releasing-Entitlements","role":"project"},"5-7-MyImageListView.swift":{"fileType":"swift","fileName":"MyImageListView.swift","syntax":"swift","identifier":"5-7-MyImageListView.swift","content":["\/\/","\/\/  MyImageListView.swift","\/\/  MyImageList","\/\/","\/\/  Copyright © 2025 Technistic Pty Ltd.","\/\/  Refer to LICENSE file for licensing terms.","\/\/","","import ImageDataPicker","import SwiftData","import SwiftUI","","let emptyPlaceholder = \"photo.fill\"","let failurePlaceholder = \"exclamationmark.triangle\"","","struct MyImageListView: View {","    @Environment(\\.dismiss) private var dismiss","    ","    @Environment(\\.modelContext) private var modelContext","    @Query private var myImages: [MyImage]","    ","    @State private var selectedImageID: MyImage.ID? = nil","    @State private var columnVisibility = NavigationSplitViewVisibility","        .doubleColumn","    ","    var body: some View {","        NavigationSplitView(columnVisibility: $columnVisibility) {","            List(selection: $selectedImageID) {","                ForEach(myImages) { myImage in","                    MyImageListRow(myImage: myImage)","                }","                .onDelete(perform: deleteMyImages)","            }","            .navigationTitle(\"My Images\")","            .environment(\\.defaultMinListRowHeight, 100)","#if os(macOS)","            .navigationSplitViewColumnWidth(min: 180, ideal: 200)","#endif","            .toolbar {","#if os(iOS)","                ToolbarItem(placement: .navigationBarTrailing) {","                    EditButton()","                }","#endif","                ToolbarItem {","                    Button(action: addImage) {","                        Label(\"Add Image\", systemImage: \"plus\")","                    }","                }","            }","        } detail: {","            if selectedImageID == nil {","                Text(\"Please select an image.\")","            } else {","                MyImageView(selectedImageID: $selectedImageID)","            }","        }","    }","    ","    \/\/\/ Add a new Image.","    \/\/\/ Initially imageData defaults to nil.","    private func addImage() {","        withAnimation {","            let newImage = MyImage(","                imageName: \"New Image\"","            )","            modelContext.insert(newImage)","            selectedImageID = newImage.persistentModelID","        }","    }","","    \/\/\/ Delete the selected Image.","    \/\/\/ - Parameter offsets: The index(es) of the rows to delete.","    private func deleteMyImages(offsets: IndexSet) {","        withAnimation {","            for index in offsets {","                let deletedImage = myImages[index]","                if deletedImage.persistentModelID == selectedImageID {","                    selectedImageID = nil","                }","                modelContext.delete(deletedImage)","                if modelContext.hasChanges {","                    do {","                        try modelContext.save()","                    }","                    catch {","                        print(\"Error: \\(error)\")","                    }","                }","            }","        }","    }","}","","\/\/ MyImageListRow","struct MyImageListRow: View {","    var myImage: MyImage?","","    var body: some View {","        @State var img: Data? = myImage?.imageData","        @State var state: ImageDataModel = ImageDataModel(imageData: img)","            ","        HStack {","            VStack {","                ImageStateView(","                    imageState: state.imageState, emptyPlaceholder: emptyPlaceholder","                )","                .foregroundColor(.white)","                .squareImageView(shape: Circle(), background: .green)","                .background(Color.blue)","            }","            .frame(width: 80, height: 80)","            Text(myImage!.imageName)","                .padding(4)","        }","    }","}","","#Preview {","    MyImageListView()","        .modelContainer(for: MyImage.self, inMemory: true)","}"],"type":"file","highlights":[{"line":13},{"line":14},{"line":15},{"line":52},{"line":54},{"line":55},{"line":104},{"line":105},{"line":106},{"line":107},{"line":108},{"line":109},{"line":110},{"line":111},{"line":112},{"line":114},{"line":121}]},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPicker/Building-CreateProject#Add-the-Framework-to-your-Project":{"url":"\/tutorials\/imagedatapicker\/building-createproject#Add-the-Framework-to-your-Project","kind":"section","title":"Add the Framework to your Project","type":"section","identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPicker\/Building-CreateProject#Add-the-Framework-to-your-Project","abstract":[{"text":"Start by creating a new SwiftUI multiplatform project for the App.","type":"text"}],"role":"pseudoSymbol"},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPicker/Building-ListView#Add-the-MyImageListView":{"kind":"section","identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPicker\/Building-ListView#Add-the-MyImageListView","title":"Add the MyImageListView","role":"pseudoSymbol","abstract":[{"text":"Create a ","type":"text"},{"code":"List","type":"codeVoice"},{"text":" view within a ","type":"text"},{"code":"NavigationSplitView","type":"codeVoice"},{"text":" to display the ","type":"text"},{"inlineContent":[{"type":"text","text":"List"}],"type":"str