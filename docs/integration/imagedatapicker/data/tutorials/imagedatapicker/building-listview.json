Picker."}]},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPicker/Releasing-Signing#Verify-App-Signing":{"type":"section","abstract":[{"text":"Review the following aspects of your app before distribution when using the xcframework form of ImageDataPicker.","type":"text"}],"identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPicker\/Releasing-Signing#Verify-App-Signing","role":"pseudoSymbol","kind":"section","url":"\/tutorials\/imagedatapicker\/releasing-signing#Verify-App-Signing","title":"Verify App Signing"},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPicker/Building-DetailView#Add-the-MyImageView":{"url":"\/tutorials\/imagedatapicker\/building-detailview#Add-the-MyImageView","kind":"section","role":"pseudoSymbol","type":"section","identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPicker\/Building-DetailView#Add-the-MyImageView","title":"Add the MyImageView","abstract":[{"text":"Add a Detail view to your SwiftUI project that allows users to view and select images.","type":"text"}]},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPickerTOC/Customizing-the-ImageDataPickerView":{"title":"Customizing the ImageDataPickerView","url":"\/tutorials\/imagedatapickertoc\/customizing-the-imagedatapickerview","abstract":[],"type":"topic","role":"article","kind":"article","identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPickerTOC\/Customizing-the-ImageDataPickerView"},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPickerTOC":{"abstract":[{"text":"Learn how to install the framework, incorporate it in your app, and prepare a shipping build for release.","type":"text"}],"url":"\/tutorials\/imagedatapickertoc","identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPickerTOC","title":"Using the ImageDataPicker Framework","role":"overview","kind":"overview","type":"topic"},"4-6-MyImageListView.swift":{"content":["\/\/","\/\/  MyImageListView.swift","\/\/  MyImageList","\/\/","\/\/  Copyright © 2025 Technistic Pty Ltd.","\/\/  Refer to LICENSE file for licensing terms.","\/\/","","import ImageDataPicker","import SwiftData","import SwiftUI","","struct MyImageListView: View {","    @Environment(\\.dismiss) private var dismiss","    ","    @Environment(\\.modelContext) private var modelContext","    @Query private var myImages: [MyImage]","    ","    @State private var selectedImageID: MyImage.ID? = nil","    @State private var columnVisibility = NavigationSplitViewVisibility","        .doubleColumn","    ","    var body: some View {","        NavigationSplitView(columnVisibility: $columnVisibility) {","            List(selection: $selectedImageID) {","                ForEach(myImages) { myImage in","                    MyImageListRow(myImage: myImage)","                }","                .onDelete(perform: deleteMyImages)","            }","            .navigationTitle(\"My Images\")","            .environment(\\.defaultMinListRowHeight, 100)","#if os(macOS)","            .navigationSplitViewColumnWidth(min: 180, ideal: 200)","#endif","            .toolbar {","#if os(iOS)","                ToolbarItem(placement: .navigationBarTrailing) {","                    EditButton()","                }","#endif","                ToolbarItem {","                    Button(action: addImage) {","                        Label(\"Add Image\", systemImage: \"plus\")","                    }","                }","            }","        } detail: {","            if let selectedImageID = selectedImageID {","                let myImage: MyImage? = modelContext.registeredModel(for: selectedImageID)","                myImage!.photo","            } else {","                Text(\"Please select an image.\")","            }","        }","    }","    ","    \/\/\/ Add a new Image.","    \/\/\/ Initially imageData defaults to nil.","    private func addImage() {","        withAnimation {","            let newImage = MyImage(","                imageName: \"New Image\"","            )","            modelContext.insert(newImage)","            selectedImageID = newImage.persistentModelID","        }","    }","","    \/\/\/ Delete the selected Image.","    \/\/\/ - Parameter offsets: The index(es) of the rows to delete.","    private func deleteMyImages(offsets: IndexSet) {","        withAnimation {","            for index in offsets {","                let deletedImage = myImages[index]","                if deletedImage.persistentModelID == selectedImageID {","                    selectedImageID = nil","                }","                modelContext.delete(deletedImage)","                if modelContext.hasChanges {","                    do {","                        try modelContext.save()","                    }","                    catch {","                        print(\"Error: \\(error)\")","                    }","                }","            }","        }","    }","}","","\/\/ MyImageListRow","struct MyImageListRow: View {","    var myImage: MyImage?","","    var body: some View {","        @State var img: Data? = myImage?.imageData","        @State var state: ImageDataModel = ImageDataModel(imageData: img)","            ","        HStack {","            ClippedImageStateView(imageState: state.imageState)","                .clippedImageShape(.round)","            Text(myImage!.imageName)","        }","        .padding(4)","    }","}","","#Preview {","    MyImageListView()","        .modelContainer(for: MyImage.self)","}"],"highlights":[{"line":9},{"line":27},{"line":89},{"line":90},{"line":91},{"line":92},{"line":93},{"line":94},{"line":95},{"line":96},{"line":97},{"line":98},{"line":99},{"line":100},{"line":101},{"line":102},{"line":103},{"line":104},{"line":106}],"fileType":"swift","fileName":"MyImageListView.swift","identifier":"4-6-MyImageListView.swift","syntax":"swift","type":"file"},"4-MyImageListView.png":{"identifier":"4-MyImageListView.png","alt":"List Background","type":"image","variants