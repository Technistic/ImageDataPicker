Framework to your Xcode project.","type":"text"}],"url":"\/tutorials\/imagedatapicker\/starting-download"},"4-5-MyImageListViewSrc.png":{"type":"image","alt":"","identifier":"4-5-MyImageListViewSrc.png","variants":[{"url":"\/images\/com.technistic.ImageDataPicker\/4-5-MyImageListViewSrc.png","traits":["1x","light"]}]},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPickerTOC/Building-an-ImageDataPicker-App":{"identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPickerTOC\/Building-an-ImageDataPicker-App","role":"article","kind":"article","title":"Building an ImageDataPicker App","url":"\/tutorials\/imagedatapickertoc\/building-an-imagedatapicker-app","abstract":[],"type":"topic"},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPicker/Building-CreateProject":{"identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPicker\/Building-CreateProject","kind":"project","role":"project","estimatedTime":"10min","title":"Create a new Project","type":"topic","abstract":[{"text":"Start by creating a new SwiftUI multiplatform project for the App.","type":"text"}],"url":"\/tutorials\/imagedatapicker\/building-createproject"},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPicker/Customizing-Clipping#Customizing-Clipping-Shapes":{"identifier":"doc:\/\/com.technistic.ImageDataPicker\/tutorials\/ImageDataPicker\/Customizing-Clipping#Customizing-Clipping-Shapes","role":"pseudoSymbol","title":"Customizing Clipping Shapes","kind":"section","url":"\/tutorials\/imagedatapicker\/customizing-clipping#Customizing-Clipping-Shapes","abstract":[{"text":"How to customize the clipping shape used by ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.technistic.ImageDataPicker\/documentation\/ImageDataPicker\/ImageDataPickerView","type":"reference"},{"text":".","type":"text"}],"type":"section"},"4-6-MyImageListView.swift":{"identifier":"4-6-MyImageListView.swift","highlights":[{"line":9},{"line":27},{"line":89},{"line":90},{"line":91},{"line":92},{"line":93},{"line":94},{"line":95},{"line":96},{"line":97},{"line":98},{"line":99},{"line":100},{"line":101},{"line":102},{"line":103},{"line":104},{"line":106}],"content":["\/\/","\/\/  MyImageListView.swift","\/\/  MyImageList","\/\/","\/\/  Copyright © 2025 Technistic Pty Ltd.","\/\/  Refer to LICENSE file for licensing terms.","\/\/","","import ImageDataPicker","import SwiftData","import SwiftUI","","struct MyImageListView: View {","    @Environment(\\.dismiss) private var dismiss","    ","    @Environment(\\.modelContext) private var modelContext","    @Query private var myImages: [MyImage]","    ","    @State private var selectedImageID: MyImage.ID? = nil","    @State private var columnVisibility = NavigationSplitViewVisibility","        .doubleColumn","    ","    var body: some View {","        NavigationSplitView(columnVisibility: $columnVisibility) {","            List(selection: $selectedImageID) {","                ForEach(myImages) { myImage in","                    MyImageListRow(myImage: myImage)","                }","                .onDelete(perform: deleteMyImages)","            }","            .navigationTitle(\"My Images\")","            .environment(\\.defaultMinListRowHeight, 100)","#if os(macOS)","            .navigationSplitViewColumnWidth(min: 180, ideal: 200)","#endif","            .toolbar {","#if os(iOS)","                ToolbarItem(placement: .navigationBarTrailing) {","                    EditButton()","                }","#endif","                ToolbarItem {","                    Button(action: addImage) {","                        Label(\"Add Image\", systemImage: \"plus\")","                    }","                }","            }","        } detail: {","            if let selectedImageID = selectedImageID {","                let myImage: MyImage? = modelContext.registeredModel(for: selectedImageID)","                myImage!.photo","            } else {","                Text(\"Please select an image.\")","            }","        }","    }","    ","    \/\/\/ Add a new Image.","    \/\/\/ Initially imageData defaults to nil.","    private func addImage() {","        withAnimation {","            let newImage = MyImage(","                imageName: \"New Image\"","            )","            modelContext.insert(newImage)","            selectedImageID = newImage.persistentModelID","        }","    }","","    \/\/\/ Delete the selected Image.","    \/\/\/ - Parameter offsets: The index(es) of the rows to delete.","    private func deleteMyImages(offsets: IndexSet) {","        withAnimation {","            for index in offsets {","                let deletedImage = myImages[index]","                if deletedImage.persistentModelID == selectedImageID {","                    selectedImageID = nil","                }","                modelContext.delete(deletedImage)","                if modelContext.hasChanges {","                    do {","                        try modelContext.save()","                    }","                    catch {","                        print(\"Error: \\(error)\")","                    }","                }","            }","        }","    }","}","","\/\/ MyImageListRow","struct MyImageListRow: View {","    var myImage: MyImage?","","    var body: some View {","        @State var img: Data? = myImage?.imageData","        @State var state: ImageDataModel = ImageDataModel(imageData: img)","            ","        HStack {","            ClippedImageStateView(imageState: state.imageState)","                .clippedImageShape(.round)","            Text(myImage!.imageName)","        }","        .padding(4)","    }","}","","#Preview {","    MyImageListView()","        .modelContainer(for: MyImage.self)","}"],"fileType":"swift","syntax":"swift","fileName":"MyImageListView.swift","type":"file"},"doc://com.technistic.ImageDataPicker/tutorials/ImageDataPicker/Starting-AddFramework#Add-with-Swift-Package-Manager":{"type":"section","abstract":[{"type":"te